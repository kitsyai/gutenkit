<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<style>
  /* Theme: every visual choice is a variable with a default, overridable via
     the `theme` data (--theme / --set) or a --css override. */
  :root {
    --font: {{ theme.font_family | default: "'Noto Sans', Arial, Helvetica, sans-serif" }};
    --fs: {{ theme.font_size | default: "10px" }};
    --text: {{ theme.text_color | default: "#111" }};
    --muted: {{ theme.muted_color | default: "#444" }};
    --rule: {{ theme.rule_color | default: "#999" }};
    --accent: {{ theme.accent_color | default: "#111" }};
    --chit: {{ theme.chit_border_color | default: "#888" }};
  }
  @page { size: {{ theme.page_size | default: "A4" }}; margin: {{ theme.page_margin | default: "14mm 14mm 12mm" }}; }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: var(--font);
    font-size: var(--fs);
    color: var(--text);
    line-height: 1.35;
  }
  .row { display: flex; justify-content: space-between; }
  .rule { border-bottom: 1px solid var(--rule); margin: 8px 0; }
  .muted { color: var(--muted); }

  /* Header */
  .supplier-name { font-size: 15px; font-weight: 700; color: var(--accent); }
  .doc-title { font-size: 15px; font-weight: 700; color: var(--accent); }
  .meta { font-size: 9px; }
  .meta div { white-space: nowrap; }
  .right { text-align: right; }
  .col-left { max-width: 55%; }
  .col-right { text-align: right; }

  /* Order summary two-column */
  .summary { display: flex; }
  .summary .c { width: 50%; }
  .kv { display: flex; }
  .kv .k { width: 120px; }
  .kv-b .k { width: 150px; font-weight: 700; }

  /* Party blocks */
  .parties { display: flex; gap: 10px; margin-top: 4px; }
  .party { width: 33.33%; }
  .party h4 { font-size: 11px; font-weight: 700; margin: 0 0 3px; }
  .party .line { }

  /* Line items */
  table.items { width: 100%; border-collapse: collapse; margin-top: 12px; font-size: 9px; }
  table.items th { font-weight: 700; text-align: right; padding: 4px 3px; border-bottom: 1px solid #333; }
  table.items td { text-align: right; padding: 5px 3px; border-bottom: 1px solid #ccc; vertical-align: top; }
  table.items th.l, table.items td.l { text-align: left; }

  /* Totals */
  .totals { margin-top: 8px; margin-left: auto; width: 45%; }
  .totals .t { display: flex; justify-content: space-between; padding: 2px 0; }
  .totals .grand { font-weight: 700; font-size: 11px; border-top: 1px solid #999; margin-top: 3px; padding-top: 4px; }

  /* Payment chit */
  .chit { border: 1px dashed var(--chit); padding: 8px 10px; margin-top: 22px; }
  .chit h4 { margin: 0 0 5px; font-size: 11px; font-weight: 700; }
  .chit .grid { display: flex; flex-wrap: wrap; }
  .chit .cell { width: 50%; display: flex; padding: 2px 0; }
  .chit .cell .k { width: 130px; }
  .chit .ack { margin-top: 6px; }

  /* Footer */
  .footer { margin-top: 20px; color: #666; font-size: 8px; }
  .footer h5 { color: #444; font-size: 9px; font-weight: 700; margin: 0 0 2px; }
  .footer .baseline { display: flex; justify-content: space-between; margin-top: 10px; }
</style>
</head>
<body>

  <!-- Header -->
  <div class="row">
    <div class="col-left">
      <div class="supplier-name">{{ supplier.legal_name | escape }}</div>
      <div class="meta muted">
        {% if supplier.cin %}<div>CIN&nbsp;&nbsp;: {{ supplier.cin }}</div>{% endif %}
        <div>GSTIN : {{ supplier.gstin }}</div>
        {% if supplier.pan %}<div>PAN&nbsp;&nbsp;: {{ supplier.pan }}</div>{% endif %}
      </div>
    </div>
    <div class="col-right">
      <div class="doc-title">{{ invoice.title | default: "Tax Invoice" }}</div>
      <div class="meta muted">
        <div>Invoice No. : {{ invoice.number }}</div>
        <div>Invoice Date : {{ invoice.date }}</div>
        {% if invoice.place_of_supply %}<div>Place of Supply : {{ invoice.place_of_supply }}</div>{% endif %}
        {% if invoice.state_code %}<div>State Code : {{ invoice.state_code }}</div>{% endif %}
      </div>
    </div>
  </div>
  <div class="rule"></div>

  <!-- Order summary -->
  <div class="summary">
    <div class="c">
      <div class="kv"><span class="k">Order No. :</span><span>{{ order.number }}</span></div>
      <div class="kv"><span class="k">Order Date :</span><span>{{ order.date }}</span></div>
      {% if invoice.document_ref %}<div class="kv"><span class="k">Document Ref :</span><span>{{ invoice.document_ref }}</span></div>{% endif %}
    </div>
    <div class="c">
      <div class="kv kv-b"><span class="k">Total Invoice Value :</span><span>{{ totals_summary.total }}</span></div>
      <div class="kv kv-b"><span class="k">Amount Paid :</span><span>{{ totals_summary.paid }}</span></div>
      <div class="kv kv-b"><span class="k">Balance Due :</span><span>{{ totals_summary.balance }}</span></div>
    </div>
  </div>
  <div class="rule"></div>

  <!-- Party blocks -->
  <div class="parties">
    {% assign parties = "Supplier,Bill to,Ship to" | split: "," %}
    <div class="party">
      <h4>Supplier</h4>
      <div class="line">{{ supplier.legal_name | escape }}</div>
      {% for l in supplier.address_lines %}<div class="line">{{ l | escape }}</div>{% endfor %}
      {% if supplier.phone %}<div class="line">Ph.No : {{ supplier.phone }}</div>{% endif %}
      {% if supplier.email %}<div class="line">E-mail : {{ supplier.email }}</div>{% endif %}
      <div class="line">GSTIN : {{ supplier.gstin }}</div>
    </div>
    <div class="party">
      <h4>Bill to</h4>
      <div class="line">{{ bill_to.name | escape }}</div>
      {% if bill_to.org %}<div class="line">{{ bill_to.org | escape }}</div>{% endif %}
      {% for l in bill_to.lines %}<div class="line">{{ l | escape }}</div>{% endfor %}
      <div class="line">GSTIN : {{ bill_to.gstin }}</div>
    </div>
    <div class="party">
      <h4>Ship to</h4>
      <div class="line">{{ ship_to.name | escape }}</div>
      {% if ship_to.org %}<div class="line">{{ ship_to.org | escape }}</div>{% endif %}
      {% for l in ship_to.lines %}<div class="line">{{ l | escape }}</div>{% endfor %}
      <div class="line">GSTIN : {{ ship_to.gstin }}</div>
    </div>
  </div>

  <!-- Line items -->
  <table class="items">
    <thead>
      <tr>
        <th class="l">Description</th><th>SAC</th><th>Qty</th><th>Duration</th>
        <th>Listed Price</th><th>Discount</th><th>Taxable Value</th><th>GST</th><th>Total</th>
      </tr>
    </thead>
    <tbody>
      {% for it in items %}
      <tr>
        <td class="l">{{ it.description | escape }}</td>
        <td>{{ it.sac }}</td>
        <td>{{ it.qty }}</td>
        <td>{{ it.duration }}</td>
        <td>{{ it.listed }}</td>
        <td>{{ it.discount }}</td>
        <td>{{ it.taxable }}</td>
        <td>{{ it.gst }}</td>
        <td>{{ it.total }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  <!-- Totals -->
  <div class="totals">
    {% for t in totals %}
    <div class="t"><span>{{ t.label }}</span><span>{{ t.value }}</span></div>
    {% endfor %}
    <div class="t grand"><span>{{ grand_total.label }}</span><span>{{ grand_total.value }}</span></div>
  </div>

  <!-- Payment chit -->
  {% if payment %}
  <div class="chit">
    <h4>Payment Details</h4>
    <div class="grid">
      {% for r in payment.rows %}
      <div class="cell"><span class="k">{{ r.lk }} :</span><span>{{ r.lv }}</span></div>
      <div class="cell"><span class="k">{{ r.rk }} :</span><span>{{ r.rv }}</span></div>
      {% endfor %}
    </div>
    {% if payment.acknowledgement %}<div class="ack">{{ payment.acknowledgement }}</div>{% endif %}
  </div>
  {% endif %}

  <!-- Footer -->
  <div class="footer">
    <h5>Terms &amp; Support</h5>
    <div>{{ footer.terms | escape }}</div>
    {% if footer.platform %}<div>Service rendered via {{ footer.platform }}.</div>{% endif %}
    <div class="baseline">
      <span>{{ footer.disclaimer }}</span>
      <span>Page 1 of 1</span>
    </div>
  </div>

</body>
</html>
