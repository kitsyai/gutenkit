<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>
:root{--font:{{ theme.font_family | default:"'Helvetica Neue',Arial,sans-serif" }};--display:{{ theme.script_font_family | default:"'Playfair Display','Georgia',serif" }};--bg:{{ theme.bg_color | default:"#f4f0e9" }};--paper:{{ theme.paper_color | default:"#fffdf9" }};--text:{{ theme.text_color | default:"#1f1d1a" }};--muted:{{ theme.muted_color | default:"#7c7469" }};--accent:{{ theme.accent_color | default:"#b48853" }};--soft:{{ theme.secondary_accent_color | default:"#e7d8c7" }};--border:{{ theme.border_color | default:"#ddd2c4" }};}
@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:24px;background:var(--bg);font-family:var(--font);color:var(--text);display:flex;justify-content:center;align-items:flex-start}.card{width:5in;min-height:7in;margin:0;background:var(--paper);border:1px solid var(--border);border-radius:24px;padding:28px;box-shadow:0 18px 44px rgba(0,0,0,.06)}.eyebrow{font-size:11px;letter-spacing:.3em;text-transform:uppercase;color:var(--muted);margin-bottom:18px}.host{max-width:330px;font-size:17px;line-height:1.55;color:var(--muted)}.names{margin:22px 0 22px}.name{margin:0;font-family:var(--display);font-size:54px;line-height:1;color:var(--text)}.join{font-size:18px;color:var(--accent);margin:8px 0}.message{font-size:18px;line-height:1.72;max-width:350px;color:#4d463f}.line{height:1px;background:var(--border);margin:26px 0}.meta{display:grid;grid-template-columns:1fr 1fr;gap:20px}.label{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);margin-bottom:8px}.value{font-family:var(--display);font-size:24px;line-height:1.4}.venue{margin-top:20px;font-size:18px;line-height:1.7;color:#47413b}.foot{margin-top:18px;font-size:14px;line-height:1.55;color:var(--muted)}
</style></head><body><div class="card"><div class="eyebrow">{{ eyebrow }}</div><div class="host">{{ host_line }}</div><div class="names"><p class="name">{{ couple.partner_one }}</p><div class="join">&amp;</div><p class="name">{{ couple.partner_two }}</p></div><div class="message">{{ message }}</div><div class="line"></div><div class="meta"><div><div class="label">Date and Time</div><div class="value">{{ date_line }}<br>{{ time_line }}</div></div><div><div class="label">Dress Code</div><div class="value">{{ dress_code }}</div></div></div><div class="venue">{{ venue_name }}<br>{{ venue_address }}</div><div class="foot">{{ celebration_note }}<br>{{ footer_note }}</div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
