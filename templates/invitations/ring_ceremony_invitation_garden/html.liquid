<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>
:root{--font:{{ theme.font_family | default:"'Cormorant Garamond','Georgia',serif" }};--script:{{ theme.script_font_family | default:"'Segoe Script','Brush Script MT',cursive" }};--bg:{{ theme.bg_color | default:"#edf4ec" }};--paper:{{ theme.paper_color | default:"#fffef9" }};--text:{{ theme.text_color | default:"#4e644d" }};--muted:{{ theme.muted_color | default:"#7f9378" }};--accent:{{ theme.accent_color | default:"#6f8b69" }};--soft:{{ theme.secondary_accent_color | default:"#d7e7cf" }};--border:{{ theme.border_color | default:"#cfddc7" }};}
@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:24px;background:linear-gradient(180deg,#f9fdf7 0%,var(--bg) 100%);font-family:var(--font);color:var(--text);display:flex;justify-content:center;align-items:flex-start}.card{width:5in;min-height:7in;margin:0;background:var(--paper);border:1px solid var(--border);border-radius:26px;padding:18px;box-shadow:0 22px 50px rgba(88,114,84,.11)}.layout{display:grid;grid-template-columns:1.05fr .95fr;min-height:calc(7in - 36px)}.side{background:linear-gradient(180deg,#6f8b69,#7f9674);border-radius:20px;color:#f7fbf4;padding:20px 18px 18px;position:relative;overflow:hidden}.side:before,.side:after{content:"";position:absolute;border-radius:999px;border:1px solid rgba(255,255,255,.16)}.side:before{width:170px;height:170px;top:-60px;left:-70px}.side:after{width:120px;height:120px;bottom:-34px;right:-36px}.side .eyebrow{font-size:12px;letter-spacing:.2em;text-transform:uppercase;margin-bottom:18px}.vert{writing-mode:vertical-rl;transform:rotate(180deg);font-size:32px;letter-spacing:.06em;margin:14px auto;height:240px;text-align:center}.side p{margin:0;font-size:15px;line-height:1.7}.main{padding:20px 0 0 16px}.host{font-size:18px;line-height:1.5;color:var(--muted);margin-bottom:14px}.name{margin:0;font-family:var(--script);font-size:48px;line-height:1.03;color:var(--accent)}.join{font-size:13px;letter-spacing:.24em;text-transform:uppercase;color:var(--muted);margin:8px 0}.message{font-size:16px;line-height:1.55;margin:16px 0}.grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}.box{padding:12px;border:1px solid var(--border);border-radius:16px;background:#fff}.label{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);margin-bottom:7px}.value{font-size:15px;line-height:1.45}.venue{margin-top:12px;padding:12px;border:1px solid var(--border);border-radius:16px;background:#fff;font-size:15px;line-height:1.5}.foot{margin-top:12px;font-size:14px;line-height:1.5;color:var(--muted)}
</style></head><body><div class="card"><div class="layout"><div class="side"><div class="eyebrow">{{ eyebrow }}</div><div class="vert">RING CEREMONY</div><p>{{ celebration_note }}</p></div><div class="main"><div class="host">{{ host_line }}</div><p class="name">{{ couple.partner_one }}</p><div class="join">and</div><p class="name">{{ couple.partner_two }}</p><div class="message">{{ message }}</div><div class="grid"><div class="box"><div class="label">Date</div><div class="value">{{ date_line }}</div></div><div class="box"><div class="label">Time</div><div class="value">{{ time_line }}<br>{{ dress_code }}</div></div></div><div class="venue">{{ venue_name }}<br>{{ venue_address }}</div><div class="foot">{{ footer_note }}</div></div></div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
