<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>:root{--font:{{ theme.font_family | default:"'Gill Sans','Segoe UI',sans-serif" }};--display:{{ theme.display_font_family | default:"'Baskerville','Times New Roman',serif" }};--bg:{{ theme.bg_color | default:"#2b1119" }};--paper:{{ theme.paper_color | default:"#fff8f5" }};--text:{{ theme.text_color | default:"#381b24" }};--muted:{{ theme.muted_color | default:"#7a5a64" }};--accent:{{ theme.accent_color | default:"#7f1d3a" }};--soft:{{ theme.secondary_accent_color | default:"#e7c9b8" }};--border:{{ theme.border_color | default:"#ddb6b0" }};}@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:24px;background:radial-gradient(circle at top,rgba(231,201,184,.15),transparent 18%),linear-gradient(180deg,#16080d 0%,var(--bg) 100%);display:flex;justify-content:center;align-items:flex-start;font-family:var(--font)}.card{width:5in;min-height:7in;padding:18px;border-radius:28px;background:linear-gradient(135deg,rgba(255,255,255,.07),rgba(255,255,255,.02));box-shadow:0 24px 60px rgba(0,0,0,.36)}.inside{height:100%;padding:24px;border-radius:22px;background:var(--paper);border:1px solid var(--border);position:relative;overflow:hidden}.inside:before{content:"";position:absolute;top:-40px;right:-20px;width:180px;height:180px;border-radius:50%;background:radial-gradient(circle,rgba(127,29,58,.14) 0 14%,transparent 15%),radial-gradient(circle at 35% 35%,rgba(231,201,184,.55),transparent 58%)}.eyebrow{font-size:11px;letter-spacing:.3em;text-transform:uppercase;color:var(--accent)}h1{margin:10px 0 8px;font-family:var(--display);font-size:32px;line-height:1.03;color:var(--accent)}.occasion{font-size:14px;line-height:1.58;color:var(--muted);max-width:292px}.host,.message{font-size:14px;line-height:1.64;margin-top:12px;color:var(--text)}.panel{margin:18px 0;padding:16px;border-radius:20px;background:linear-gradient(180deg,rgba(127,29,58,.95),rgba(97,17,42,.95));color:#fff}.panel .label{font-size:10px;letter-spacing:.24em;text-transform:uppercase;color:#f6ddd0;margin-bottom:8px}.panel .value{font-size:13px;line-height:1.55}.chips{display:grid;gap:8px}.chip{padding:10px 12px;border-radius:999px;background:rgba(231,201,184,.42);font-size:12px;line-height:1.45;text-align:center}.footer{margin-top:14px;padding-top:12px;border-top:1px solid var(--border);font-size:12px;line-height:1.6;color:var(--muted)}</style></head><body><div class="card"><div class="inside"><div class="eyebrow">{{ eyebrow }}</div><h1>{{ title }}</h1><div class="occasion">{{ occasion }}</div><div class="host">{{ host_line }}</div><div class="message">{{ message }}</div><div class="panel"><div class="label">Event Details</div><div class="value">{{ date_line }}<br>{{ time_line }}<br>{{ venue_name }}<br>{{ venue_address }}</div></div><div class="chips">{% for item in highlights limit:3 %}<div class="chip">{{ item }}</div>{% endfor %}</div><div class="footer">{{ dress_code }}<br>{{ rsvp }}<br>{{ footer_note }}</div></div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
