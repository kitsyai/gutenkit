<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>
:root{--font:{{ theme.font_family | default:"'Trebuchet MS','Segoe UI',sans-serif" }};--display:{{ theme.display_font_family | default:"'Cooper Black','Trebuchet MS',sans-serif" }};--bg:{{ theme.bg_color | default:"#fff6de" }};--paper:{{ theme.paper_color | default:"#fffdf8" }};--text:{{ theme.text_color | default:"#43302b" }};--muted:{{ theme.muted_color | default:"#8c5a52" }};--accent:{{ theme.accent_color | default:"#ff5f6d" }};--accent2:{{ theme.accent_two_color | default:"#ffb703" }};--accent3:{{ theme.accent_three_color | default:"#4cc9f0" }};--border:{{ theme.border_color | default:"#ffd7b3" }};}
@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:20px;font-family:var(--font);background:var(--bg);color:var(--text);display:flex;justify-content:center;align-items:flex-start}.card{width:5in;min-height:7in;border-radius:30px;padding:24px;background:var(--paper);border:2px solid var(--border);box-shadow:0 18px 40px rgba(170,101,74,.12)}.dots{display:flex;justify-content:center;gap:10px;margin-bottom:14px}.dots span{width:14px;height:14px;border-radius:50%}.dots span:nth-child(1){background:var(--accent)}.dots span:nth-child(2){background:var(--accent2)}.dots span:nth-child(3){background:var(--accent3)}.eyebrow{text-align:center;font-size:12px;letter-spacing:.3em;text-transform:uppercase;color:var(--accent)}.badge{width:96px;height:96px;margin:16px auto 12px;border-radius:50%;display:grid;place-items:center;background:linear-gradient(135deg,var(--accent),var(--accent2));font-family:var(--display);font-size:34px;color:#fff}.name{text-align:center;margin:0;font-family:var(--display);font-size:50px;line-height:1}.host,.message{text-align:center}.host{margin:10px auto 0;max-width:320px;font-size:17px;line-height:1.55;color:var(--muted)}.message{margin:16px auto 0;max-width:344px;font-size:15px;line-height:1.6}.grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:18px}.panel{padding:14px;border-radius:18px;background:#fff;border:1px solid var(--border)}.panel.wide{grid-column:1/-1}.label{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);margin-bottom:7px}.value{font-size:15px;line-height:1.55}.footer{margin-top:14px;padding:13px 14px;border-radius:18px;background:rgba(255,183,3,.14);font-size:14px;line-height:1.55;text-align:center;color:var(--muted)}
</style></head><body><div class="card"><div class="dots"><span></span><span></span><span></span></div><div class="eyebrow">{{ eyebrow }}</div><div class="badge">{{ age }}</div><p class="name">{{ honoree_name }}</p><div class="host">{{ host_line }}</div><div class="message">{{ message }}</div><div class="grid"><div class="panel"><div class="label">Date</div><div class="value">{{ date_line }}</div></div><div class="panel"><div class="label">Time</div><div class="value">{{ time_line }}</div></div><div class="panel wide"><div class="label">Venue</div><div class="value">{{ venue_name }}<br>{{ venue_address }}</div></div><div class="panel wide"><div class="label">Dress Code</div><div class="value">{{ dress_code }}</div></div></div><div class="footer">{{ celebration_note }}<br>{{ rsvp }}</div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
