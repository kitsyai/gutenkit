<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>
:root{--font:{{ theme.font_family | default:"'Garamond','Georgia',serif" }};--script:{{ theme.script_font_family | default:"'Palace Script MT','Brush Script MT',cursive" }};--bg:{{ theme.bg_color | default:"#f3efe6" }};--paper:{{ theme.paper_color | default:"#fffaf1" }};--text:{{ theme.text_color | default:"#4e3526" }};--muted:{{ theme.muted_color | default:"#8a6a43" }};--accent:{{ theme.accent_color | default:"#0f5c4b" }};--gold:{{ theme.secondary_accent_color | default:"#d6b36e" }};--border:{{ theme.border_color | default:"#dcc39c" }};}
@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:24px;background:linear-gradient(180deg,#fbf7ef 0%,var(--bg) 100%);font-family:var(--font);color:var(--text);display:flex;justify-content:center;align-items:flex-start}.card{width:5in;min-height:7in;margin:0;background:var(--paper);border:1px solid var(--border);border-radius:26px;padding:16px;box-shadow:0 24px 55px rgba(98,78,47,.12)}.frame{height:100%;border:2px solid rgba(214,179,110,.55);border-radius:20px;padding:26px 24px 22px;position:relative;overflow:hidden}.frame:before,.frame:after{content:"";position:absolute;top:26px;bottom:26px;width:28px;border-left:1px solid rgba(214,179,110,.38);border-right:1px solid rgba(214,179,110,.38);background:linear-gradient(180deg,rgba(214,179,110,.12),transparent)}.frame:before{left:18px}.frame:after{right:18px}.crest{text-align:center;color:var(--gold);font-size:24px;letter-spacing:.12em}.eyebrow,.host{text-align:center}.eyebrow{font-size:12px;letter-spacing:.24em;text-transform:uppercase;color:var(--muted);margin-top:6px}.host{font-size:15px;color:var(--accent);margin:10px 0 14px}.arch{max-width:340px;margin:0 auto;padding:26px 18px 18px;border:1px solid rgba(220,195,156,.92);border-top-left-radius:200px;border-top-right-radius:200px;border-bottom-left-radius:14px;border-bottom-right-radius:14px;background:linear-gradient(180deg,rgba(255,255,255,.92),rgba(255,248,238,.96))}.name{margin:0;font-family:var(--script);font-size:50px;line-height:1.02;color:var(--accent);text-align:center}.join{text-align:center;font-size:18px;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);margin:6px 0}.message{text-align:center;font-size:17px;line-height:1.6;margin:16px auto 18px;max-width:350px}.meta{text-align:center;border-top:1px solid rgba(220,195,156,.86);border-bottom:1px solid rgba(220,195,156,.86);padding:14px 0;margin:0 auto 14px;max-width:320px}.meta strong{display:block;font-size:17px;color:var(--accent)}.venue{text-align:center;font-size:17px;line-height:1.55}.foot{text-align:center;margin-top:16px;font-size:14px;line-height:1.55;color:var(--muted)}
</style></head><body><div class="card"><div class="frame"><div class="crest">RING CELEBRATION</div><div class="eyebrow">{{ eyebrow }}</div><div class="host">{{ host_line }}</div><div class="arch"><p class="name">{{ couple.partner_one }}</p><div class="join">and</div><p class="name">{{ couple.partner_two }}</p><div class="message">{{ message }}</div></div><div class="meta"><div>{{ date_line }}</div><strong>{{ time_line }}</strong><div>{{ dress_code }}</div></div><div class="venue">{{ venue_name }}<br>{{ venue_address }}</div><div class="foot">{{ celebration_note }}<br>{{ footer_note }}</div></div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
