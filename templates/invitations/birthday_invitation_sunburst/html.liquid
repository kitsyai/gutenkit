<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>
:root{--font:{{ theme.font_family | default:"'Verdana','Segoe UI',sans-serif" }};--display:{{ theme.display_font_family | default:"'Gill Sans','Trebuchet MS',sans-serif" }};--bg:{{ theme.bg_color | default:"#fff0cf" }};--paper:{{ theme.paper_color | default:"#fffaf0" }};--text:{{ theme.text_color | default:"#4a2d20" }};--muted:{{ theme.muted_color | default:"#936248" }};--accent:{{ theme.accent_color | default:"#ff7a21" }};--accent2:{{ theme.accent_two_color | default:"#ffd166" }};--border:{{ theme.border_color | default:"#f0d1a2" }};}
@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:20px;background:var(--bg);font-family:var(--font);color:var(--text);display:flex;justify-content:center;align-items:flex-start}.card{overflow:hidden;width:5in;min-height:7in;background:var(--paper);border-radius:28px;border:1px solid var(--border);box-shadow:0 18px 40px rgba(176,109,40,.12)}.hero{padding:22px;background:repeating-linear-gradient(90deg,rgba(255,122,33,.12) 0 18px,rgba(255,209,102,.12) 18px 36px)}.eyebrow{text-align:center;font-size:12px;letter-spacing:.32em;text-transform:uppercase;color:var(--accent)}.name{margin:16px 0 0;text-align:center;font-family:var(--display);font-size:46px;line-height:1;text-transform:uppercase}.age{text-align:center;margin-top:8px;font-size:20px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted)}.body{padding:22px}.host{text-align:center;font-size:17px;line-height:1.6;color:var(--muted)}.message{margin-top:16px;padding:14px 16px;border-radius:18px;background:#fff;font-size:15px;line-height:1.62;text-align:center}.details{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:16px}.box{padding:14px;border-radius:18px;background:#fff;border:1px solid var(--border)}.box.wide{grid-column:1/-1}.label{font-size:10px;letter-spacing:.24em;text-transform:uppercase;color:var(--muted);margin-bottom:7px}.value{font-size:15px;line-height:1.5}.footer{margin-top:14px;text-align:center;font-size:14px;line-height:1.55;color:var(--muted)}
</style></head><body><div class="card"><div class="hero"><div class="eyebrow">{{ eyebrow }}</div><p class="name">{{ honoree_name }}</p><div class="age">Turns {{ age }}</div></div><div class="body"><div class="host">{{ host_line }}</div><div class="message">{{ message }}</div><div class="details"><div class="box"><div class="label">Date</div><div class="value">{{ date_line }}</div></div><div class="box"><div class="label">Time</div><div class="value">{{ time_line }}</div></div><div class="box wide"><div class="label">Venue</div><div class="value">{{ venue_name }}<br>{{ venue_address }}</div></div><div class="box"><div class="label">Look</div><div class="value">{{ dress_code }}</div></div><div class="box"><div class="label">RSVP</div><div class="value">{{ rsvp }}</div></div></div><div class="footer">{{ celebration_note }}</div></div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
