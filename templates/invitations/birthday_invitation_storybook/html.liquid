<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>
:root{--font:{{ theme.font_family | default:"'Book Antiqua',Georgia,serif" }};--display:{{ theme.display_font_family | default:"'Lucida Calligraphy','Palatino Linotype',serif" }};--bg:{{ theme.bg_color | default:"#f6efe4" }};--paper:{{ theme.paper_color | default:"#fffaf2" }};--text:{{ theme.text_color | default:"#4e3b2f" }};--muted:{{ theme.muted_color | default:"#917360" }};--accent:{{ theme.accent_color | default:"#bb7b6f" }};--accent2:{{ theme.accent_two_color | default:"#d7bc84" }};--border:{{ theme.border_color | default:"#e6d5bd" }};}
@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:22px;background:var(--bg);font-family:var(--font);color:var(--text);display:flex;justify-content:center;align-items:flex-start}.card{width:5in;min-height:7in;padding:22px;background:var(--paper);border:1px solid var(--border);border-radius:18px;box-shadow:0 18px 40px rgba(114,92,78,.1)}.frame{height:100%;padding:22px;border:4px solid var(--accent2);border-radius:16px}.eyebrow{text-align:center;font-size:11px;letter-spacing:.26em;text-transform:uppercase;color:var(--muted)}.name{margin:18px 0 0;font-family:var(--display);font-size:42px;line-height:1.12;text-align:center;color:var(--accent)}.age{text-align:center;margin-top:8px;font-size:20px;letter-spacing:.18em;text-transform:uppercase}.host{margin:14px auto 0;max-width:320px;text-align:center;font-size:17px;line-height:1.65;color:var(--muted)}.chapter{margin-top:18px;padding:14px 16px;border-radius:16px;background:#fff;font-size:15px;line-height:1.64;text-align:center}.grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:16px}.panel{padding:13px;border-radius:16px;background:#fff;border:1px solid var(--border)}.panel.wide{grid-column:1/-1}.label{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);margin-bottom:7px}.value{font-size:15px;line-height:1.52}.footer{margin-top:14px;text-align:center;font-size:14px;line-height:1.58;color:var(--muted)}
</style></head><body><div class="card"><div class="frame"><div class="eyebrow">{{ eyebrow }}</div><p class="name">{{ honoree_name }}</p><div class="age">Turning {{ age }}</div><div class="host">{{ host_line }}</div><div class="chapter">{{ message }}</div><div class="grid"><div class="panel"><div class="label">Date</div><div class="value">{{ date_line }}</div></div><div class="panel"><div class="label">Time</div><div class="value">{{ time_line }}</div></div><div class="panel wide"><div class="label">Venue</div><div class="value">{{ venue_name }}<br>{{ venue_address }}</div></div><div class="panel"><div class="label">Attire</div><div class="value">{{ dress_code }}</div></div><div class="panel"><div class="label">RSVP</div><div class="value">{{ rsvp }}</div></div></div><div class="footer">{{ celebration_note }}</div></div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
