<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>
:root{--font:{{ theme.font_family | default:"'Georgia',serif" }};--display:{{ theme.display_font_family | default:"'Palatino Linotype','Book Antiqua',serif" }};--bg:{{ theme.bg_color | default:"#eef7ee" }};--paper:{{ theme.paper_color | default:"#fffef9" }};--text:{{ theme.text_color | default:"#31443a" }};--muted:{{ theme.muted_color | default:"#718674" }};--accent:{{ theme.accent_color | default:"#8cba7d" }};--accent2:{{ theme.accent_two_color | default:"#d7a7b7" }};--accent3:{{ theme.accent_three_color | default:"#f4d9a6" }};--border:{{ theme.border_color | default:"#dbe7d7" }};}
@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:22px;background:linear-gradient(180deg,#f8fcf7 0%,var(--bg) 100%);font-family:var(--font);color:var(--text);display:flex;justify-content:center;align-items:flex-start}.card{position:relative;overflow:hidden;width:5in;min-height:7in;padding:24px;border-radius:24px;background:var(--paper);border:1px solid var(--border);box-shadow:0 20px 46px rgba(103,129,106,.12)}.card:before,.card:after{content:"";position:absolute;border-radius:50%;filter:blur(2px)}.card:before{width:220px;height:220px;top:-70px;right:-80px;background:radial-gradient(circle,rgba(215,167,183,.24),transparent 68%)}.card:after{width:220px;height:220px;left:-70px;bottom:-70px;background:radial-gradient(circle,rgba(140,186,125,.2),transparent 68%)}.layout{display:grid;grid-template-columns:120px 1fr;gap:18px;height:100%}.sidebar{border-radius:20px;padding:16px 12px;background:linear-gradient(180deg,rgba(140,186,125,.16),rgba(255,255,255,.75));border:1px solid rgba(219,231,215,.92);display:flex;flex-direction:column;justify-content:space-between}.petals{height:140px;border-radius:18px;background:
radial-gradient(circle at 50% 22%,rgba(215,167,183,.78) 0 17px,transparent 18px),
radial-gradient(circle at 24% 46%,rgba(244,217,166,.78) 0 19px,transparent 20px),
radial-gradient(circle at 76% 46%,rgba(140,186,125,.78) 0 19px,transparent 20px),
radial-gradient(circle at 50% 72%,rgba(215,167,183,.72) 0 18px,transparent 19px);
background-color:rgba(255,255,255,.65)}.age{font-family:var(--display);font-size:46px;text-align:center;color:var(--accent)}.eyebrow{text-align:center;font-size:11px;letter-spacing:.28em;text-transform:uppercase;color:var(--muted)}.main{padding:10px 4px 4px}.name{margin:8px 0 0;font-family:var(--display);font-size:48px;line-height:1;color:var(--text)}.host{margin-top:12px;font-size:17px;line-height:1.65;color:var(--muted)}.message{margin-top:18px;padding:16px 18px;border-radius:18px;background:rgba(255,255,255,.78);border:1px solid rgba(219,231,215,.94);font-size:15px;line-height:1.65}.details{display:grid;gap:12px;margin-top:14px}.row{display:grid;grid-template-columns:1fr 1fr;gap:12px}.box{padding:13px 14px;border-radius:16px;background:#fff;border:1px solid var(--border)}.label{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);margin-bottom:7px}.value{font-size:15px;line-height:1.52}.foot{margin-top:12px;font-size:14px;line-height:1.6;color:var(--muted)}@media (max-width:640px){.layout{grid-template-columns:1fr}.sidebar{flex-direction:row;align-items:center}.petals{width:120px;height:100px}}
</style></head><body><div class="card"><div class="layout"><div class="sidebar"><div class="eyebrow">{{ eyebrow }}</div><div class="petals"></div><div class="age">{{ age }}</div></div><div class="main"><p class="name">{{ honoree_name }}</p><div class="host">{{ host_line }}</div><div class="message">{{ message }}</div><div class="details"><div class="row"><div class="box"><div class="label">Date</div><div class="value">{{ date_line }}</div></div><div class="box"><div class="label">Time</div><div class="value">{{ time_line }}</div></div></div><div class="box"><div class="label">Venue</div><div class="value">{{ venue_name }}<br>{{ venue_address }}</div></div><div class="row"><div class="box"><div class="label">Dress</div><div class="value">{{ dress_code }}</div></div><div class="box"><div class="label">RSVP</div><div class="value">{{ rsvp }}</div></div></div></div><div class="foot">{{ celebration_note }}</div></div></div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
