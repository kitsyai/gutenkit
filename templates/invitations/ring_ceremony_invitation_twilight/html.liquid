<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>
:root{--font:{{ theme.font_family | default:"'Cormorant Garamond','Georgia',serif" }};--script:{{ theme.script_font_family | default:"'Great Vibes','Segoe Script',cursive" }};--bg:{{ theme.bg_color | default:"#efe8f7" }};--paper:{{ theme.paper_color | default:"#fffdfd" }};--text:{{ theme.text_color | default:"#493852" }};--muted:{{ theme.muted_color | default:"#876f92" }};--accent:{{ theme.accent_color | default:"#7e5aa6" }};--soft:{{ theme.secondary_accent_color | default:"#d4c1e8" }};--border:{{ theme.border_color | default:"#dfd3eb" }};}
@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:24px;background:linear-gradient(180deg,#faf7ff 0%,var(--bg) 100%);font-family:var(--font);color:var(--text);display:flex;justify-content:center;align-items:flex-start}.card{width:5in;min-height:7in;margin:0;border-radius:28px;padding:18px;background:var(--paper);border:1px solid var(--border);box-shadow:0 24px 56px rgba(89,72,105,.12)}.layout{display:grid;grid-template-columns:.86fr 1.14fr;min-height:calc(7in - 36px);gap:14px}.side{border-radius:20px;background:linear-gradient(180deg,#7e5aa6,#624483);color:#faf6ff;padding:20px 16px;display:flex;flex-direction:column;justify-content:space-between;position:relative;overflow:hidden}.side:before{content:"";position:absolute;width:160px;height:160px;border-radius:50%;border:1px solid rgba(255,255,255,.12);top:-70px;right:-50px}.side .eyebrow{font-size:12px;letter-spacing:.22em;text-transform:uppercase}.badge{font-size:30px;line-height:1.1}.side p{margin:0;font-size:15px;line-height:1.6}.main{border:1px solid var(--border);border-radius:20px;padding:22px 20px}.host{font-size:17px;line-height:1.5;color:var(--muted)}.name{margin:14px 0 0;font-family:var(--script);font-size:46px;line-height:1.04;color:var(--accent)}.join{font-size:13px;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);margin:8px 0}.message{font-size:16px;line-height:1.58;margin:14px 0}.box{padding:12px;border:1px solid var(--border);border-radius:16px;background:#fff;margin-top:10px}.label{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);margin-bottom:7px}.value{font-size:15px;line-height:1.45}.foot{margin-top:12px;font-size:14px;line-height:1.55;color:var(--muted)}
</style></head><body><div class="card"><div class="layout"><div class="side"><div><div class="eyebrow">{{ eyebrow }}</div><div class="badge">RING NIGHT</div></div><p>{{ celebration_note }}</p><p>{{ footer_note }}</p></div><div class="main"><div class="host">{{ host_line }}</div><p class="name">{{ couple.partner_one }}</p><div class="join">and</div><p class="name">{{ couple.partner_two }}</p><div class="message">{{ message }}</div><div class="box"><div class="label">Date and Time</div><div class="value">{{ date_line }}<br>{{ time_line }}</div></div><div class="box"><div class="label">Venue</div><div class="value">{{ venue_name }}<br>{{ venue_address }}</div></div><div class="foot">{{ dress_code }}</div></div></div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
