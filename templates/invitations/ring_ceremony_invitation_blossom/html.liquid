<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>
:root{--font:{{ theme.font_family | default:"'Cormorant Garamond','Georgia',serif" }};--script:{{ theme.script_font_family | default:"'Lucida Handwriting','Segoe Script',cursive" }};--bg:{{ theme.bg_color | default:"#fff1f7" }};--paper:{{ theme.paper_color | default:"#fffdfd" }};--text:{{ theme.text_color | default:"#74485f" }};--muted:{{ theme.muted_color | default:"#a6778b" }};--accent:{{ theme.accent_color | default:"#cc7498" }};--soft:{{ theme.secondary_accent_color | default:"#f5c6dc" }};--border:{{ theme.border_color | default:"#f1d7e5" }};}
@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:24px;background:linear-gradient(180deg,#fff8fb 0%,var(--bg) 100%);font-family:var(--font);color:var(--text);display:flex;justify-content:center;align-items:flex-start}.card{width:5in;min-height:7in;margin:0;background:var(--paper);border:1px solid var(--border);border-radius:28px;padding:24px;box-shadow:0 24px 56px rgba(151,104,127,.11)}.inner{position:relative;height:100%;border-radius:22px;border:1px solid rgba(241,215,229,.95);padding:30px 28px 26px;overflow:hidden}.petal,.petal:before{position:absolute;border-radius:50%;content:""}.petal{width:110px;height:110px;background:radial-gradient(circle,rgba(245,198,220,.42),transparent 66%)}.petal:before{width:26px;height:26px;background:rgba(204,116,152,.18);top:18px;left:18px}.p1{top:-32px;left:-26px}.p2{top:18px;right:-28px}.p3{bottom:-28px;left:24px}.p4{bottom:10px;right:-22px}.eyebrow,.host,.message,.venue,.foot{text-align:center}.eyebrow{font-size:12px;letter-spacing:.24em;text-transform:uppercase;color:var(--muted)}.host{font-size:17px;line-height:1.45;margin:8px auto 16px;max-width:330px}.name{margin:0;text-align:center;font-family:var(--script);font-size:46px;line-height:1.08;color:var(--accent)}.join{text-align:center;color:var(--muted);text-transform:uppercase;letter-spacing:.24em;font-size:12px;margin:8px 0}.message{font-size:17px;line-height:1.62;margin:16px auto;max-width:350px}.band{max-width:330px;margin:0 auto 16px;padding:12px 16px;border-radius:999px;border:1px solid var(--border);background:rgba(255,255,255,.74);text-align:center;color:var(--accent);font-size:15px}.grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}.box{padding:14px 12px;border:1px solid var(--border);border-radius:16px;background:rgba(255,255,255,.72);text-align:center}.label{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);margin-bottom:8px}.value{font-size:16px;line-height:1.5}.venue{margin-top:14px;font-size:16px;line-height:1.55}.foot{margin-top:14px;font-size:14px;line-height:1.55;color:var(--muted)}
</style></head><body><div class="card"><div class="inner"><div class="petal p1"></div><div class="petal p2"></div><div class="petal p3"></div><div class="petal p4"></div><div class="eyebrow">{{ eyebrow }}</div><div class="host">{{ host_line }}</div><p class="name">{{ couple.partner_one }}</p><div class="join">and</div><p class="name">{{ couple.partner_two }}</p><div class="message">{{ message }}</div><div class="band">{{ celebration_note }}</div><div class="grid"><div class="box"><div class="label">Date</div><div class="value">{{ date_line }}</div></div><div class="box"><div class="label">Time</div><div class="value">{{ time_line }}<br>{{ dress_code }}</div></div></div><div class="venue">{{ venue_name }}<br>{{ venue_address }}</div><div class="foot">{{ footer_note }}</div></div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
