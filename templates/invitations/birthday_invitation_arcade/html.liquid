<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>
:root{--font:{{ theme.font_family | default:"'Courier New',monospace" }};--display:{{ theme.display_font_family | default:"'Arial Black',sans-serif" }};--bg:{{ theme.bg_color | default:"#fff4d8" }};--paper:{{ theme.paper_color | default:"#fffdf7" }};--text:{{ theme.text_color | default:"#2c2f45" }};--muted:{{ theme.muted_color | default:"#6f7291" }};--accent:{{ theme.accent_color | default:"#ffcf33" }};--accent2:{{ theme.accent_two_color | default:"#18f2b2" }};--accent3:{{ theme.accent_three_color | default:"#ff5d8f" }};--border:{{ theme.border_color | default:"#ffd77b" }};}
@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:20px;background:var(--bg);font-family:var(--font);color:var(--text);display:flex;justify-content:center;align-items:flex-start}.card{width:5in;min-height:7in;padding:22px;background:var(--paper);border:3px solid var(--border);box-shadow:8px 8px 0 rgba(255,207,51,.28)}.top{display:flex;justify-content:space-between;align-items:center;gap:12px}.eyebrow{display:inline-block;padding:6px 10px;background:var(--accent2);color:#083126;font-size:11px;letter-spacing:.18em;text-transform:uppercase}.age{padding:8px 12px;background:var(--accent3);color:#fff;font-family:var(--display);font-size:26px}.name{margin:18px 0 0;font-family:var(--display);font-size:44px;line-height:1;text-transform:uppercase}.host{margin-top:10px;font-size:16px;line-height:1.58;color:var(--muted)}.message{margin-top:16px;padding:14px;border:2px solid var(--accent2);background:#fff;font-size:15px;line-height:1.6}.stats{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:16px}.box{padding:12px;border:2px solid var(--border);background:#fff}.box.wide{grid-column:1/-1}.label{font-size:10px;color:var(--accent3);margin-bottom:6px;text-transform:uppercase}.value{font-size:15px;line-height:1.5}.footer{margin-top:14px;padding:12px;background:rgba(255,207,51,.18);font-size:14px;line-height:1.55;color:var(--muted)}
</style></head><body><div class="card"><div class="top"><div class="eyebrow">{{ eyebrow }}</div><div class="age">{{ age }}</div></div><p class="name">{{ honoree_name }}</p><div class="host">{{ host_line }}</div><div class="message">{{ message }}</div><div class="stats"><div class="box"><div class="label">Date</div><div class="value">{{ date_line }}</div></div><div class="box"><div class="label">Time</div><div class="value">{{ time_line }}</div></div><div class="box wide"><div class="label">Location</div><div class="value">{{ venue_name }}<br>{{ venue_address }}</div></div><div class="box"><div class="label">Dress Code</div><div class="value">{{ dress_code }}</div></div><div class="box"><div class="label">RSVP</div><div class="value">{{ rsvp }}</div></div></div><div class="footer">{{ celebration_note }}</div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
