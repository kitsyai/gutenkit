<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>
:root{--font:{{ theme.font_family | default:"'Cormorant Garamond','Georgia',serif" }};--script:{{ theme.script_font_family | default:"'Segoe Script','Brush Script MT',cursive" }};--bg:{{ theme.bg_color | default:"#f4efff" }};--paper:{{ theme.paper_color | default:"#fffdfd" }};--text:{{ theme.text_color | default:"#56416e" }};--muted:{{ theme.muted_color | default:"#8c79a8" }};--accent:{{ theme.accent_color | default:"#a66fe8" }};--soft:{{ theme.secondary_accent_color | default:"#f6cde8" }};--border:{{ theme.border_color | default:"#e7d8fb" }};}
@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:24px;font-family:var(--font);background:radial-gradient(circle at top,#fff8ff 0%,var(--bg) 58%,#efe9ff 100%);color:var(--text);display:flex;justify-content:center;align-items:flex-start}.card{width:5in;min-height:7in;margin:0;border-radius:28px;padding:24px;background:linear-gradient(180deg,rgba(255,255,255,.95),rgba(255,249,255,.92));border:1px solid var(--border);box-shadow:0 26px 60px rgba(104,82,140,.14)}.inner{position:relative;height:100%;border-radius:22px;padding:30px 28px 24px;border:1px solid rgba(231,216,251,.95);overflow:hidden}.inner:before,.inner:after{content:"";position:absolute;border-radius:50%;background:radial-gradient(circle,rgba(166,111,232,.18),transparent 64%)}.inner:before{width:190px;height:190px;top:-70px;left:-60px}.inner:after{width:220px;height:220px;right:-90px;bottom:-90px}.eyebrow,.host{text-align:center}.eyebrow{font-size:12px;letter-spacing:.28em;text-transform:uppercase;color:var(--muted)}.host{font-size:17px;line-height:1.5;margin:8px 0 18px;color:var(--text)}.ring{width:120px;height:120px;margin:0 auto 16px;border-radius:50%;display:grid;place-items:center;border:1px solid var(--soft);box-shadow:inset 0 0 0 10px rgba(246,205,232,.26)}.ring div{width:58px;height:58px;border-radius:50%;border:4px solid var(--accent);border-right-color:transparent;transform:rotate(-18deg);position:relative}.ring div:after{content:"";position:absolute;width:58px;height:58px;border-radius:50%;border:4px solid rgba(246,205,232,.96);left:30px;top:16px}.name{margin:0;text-align:center;font-family:var(--script);font-size:52px;line-height:1.02;color:var(--accent)}.join{text-align:center;text-transform:uppercase;letter-spacing:.24em;color:var(--muted);font-size:13px;margin:8px 0}.message{text-align:center;font-size:18px;line-height:1.6;margin:14px auto 18px;max-width:360px}.details{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:6px}.detail,.footer{background:rgba(255,255,255,.66);border:1px solid rgba(231,216,251,.96);border-radius:16px}.detail{padding:14px 12px;text-align:center}.label{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);margin-bottom:7px}.value{font-size:17px;line-height:1.5}.venue{grid-column:1/-1}.footer{margin-top:12px;padding:14px 16px;text-align:center;font-size:15px;line-height:1.55;color:var(--muted)}
</style></head><body><div class="card"><div class="inner"><div class="eyebrow">{{ eyebrow }}</div><div class="host">{{ host_line }}</div><div class="ring"><div></div></div><p class="name">{{ couple.partner_one }}</p><div class="join">and</div><p class="name">{{ couple.partner_two }}</p><div class="message">{{ message }}</div><div class="details"><div class="detail"><div class="label">Date</div><div class="value">{{ date_line }}</div></div><div class="detail"><div class="label">Time</div><div class="value">{{ time_line }}<br>{{ dress_code }}</div></div><div class="detail venue"><div class="label">Venue</div><div class="value">{{ venue_name }}<br>{{ venue_address }}</div></div></div><div class="footer">{{ celebration_note }}<br>{{ footer_note }}</div></div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
