<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>
:root{--font:{{ theme.font_family | default:"'Cormorant Garamond','Georgia',serif" }};--script:{{ theme.script_font_family | default:"'Great Vibes','Segoe Script',cursive" }};--bg:{{ theme.bg_color | default:"#f6f3ed" }};--paper:{{ theme.paper_color | default:"#fffefb" }};--text:{{ theme.text_color | default:"#574b41" }};--muted:{{ theme.muted_color | default:"#998a7f" }};--accent:{{ theme.accent_color | default:"#c49b63" }};--soft:{{ theme.secondary_accent_color | default:"#ebe1d2" }};--border:{{ theme.border_color | default:"#ddd0bf" }};}
@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:24px;background:linear-gradient(180deg,#fffdf9 0%,var(--bg) 100%);font-family:var(--font);color:var(--text);display:flex;justify-content:center;align-items:flex-start}.card{width:5in;min-height:7in;margin:0;background:var(--paper);border:1px solid var(--border);border-radius:28px;padding:18px;box-shadow:0 22px 52px rgba(118,104,90,.11)}.frame{height:100%;border:1px solid rgba(221,208,191,.95);border-radius:24px;padding:28px 24px 22px;position:relative;background:linear-gradient(180deg,rgba(255,255,255,.92),rgba(251,247,240,.92))}.frame:before,.frame:after{content:"";position:absolute;border-radius:50%;background:radial-gradient(circle,rgba(196,155,99,.18),transparent 66%)}.frame:before{width:160px;height:160px;top:-80px;right:-40px}.frame:after{width:120px;height:120px;bottom:-46px;left:-24px}.eyebrow,.host,.message,.venue,.foot{text-align:center}.eyebrow{font-size:12px;letter-spacing:.26em;text-transform:uppercase;color:var(--muted)}.host{font-size:17px;line-height:1.55;margin:10px auto 16px;max-width:300px}.oval{max-width:330px;margin:0 auto;padding:18px;border:1px solid var(--border);border-radius:180px;background:#fff}.name{margin:0;font-family:var(--script);font-size:48px;line-height:1.05;color:var(--accent)}.join{text-align:center;font-size:14px;letter-spacing:.24em;text-transform:uppercase;color:var(--muted);margin:10px 0}.message{font-size:16px;line-height:1.62;max-width:340px;margin:18px auto}.meta{display:grid;grid-template-columns:1fr 1fr;gap:10px}.box{padding:12px;border:1px solid var(--border);border-radius:16px;background:rgba(255,255,255,.82);text-align:center}.label{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:7px}.value{font-size:15px;line-height:1.45}.venue{margin-top:12px;font-size:16px;line-height:1.55}.foot{margin-top:14px;font-size:14px;line-height:1.55;color:var(--muted)}
</style></head><body><div class="card"><div class="frame"><div class="eyebrow">{{ eyebrow }}</div><div class="host">{{ host_line }}</div><div class="oval"><p class="name">{{ couple.partner_one }}</p><div class="join">and</div><p class="name">{{ couple.partner_two }}</p></div><div class="message">{{ message }}</div><div class="meta"><div class="box"><div class="label">Date</div><div class="value">{{ date_line }}</div></div><div class="box"><div class="label">Time</div><div class="value">{{ time_line }}<br>{{ dress_code }}</div></div></div><div class="venue">{{ venue_name }}<br>{{ venue_address }}</div><div class="foot">{{ celebration_note }}<br>{{ footer_note }}</div></div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
