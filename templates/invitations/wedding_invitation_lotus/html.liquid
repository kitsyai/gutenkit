<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>
:root{--font:{{ theme.font_family | default:"'Georgia',serif" }};--script:{{ theme.script_font_family | default:"'Great Vibes','Segoe Script',cursive" }};--bg:{{ theme.bg_color | default:"#fff3ec" }};--paper:{{ theme.paper_color | default:"#fffaf5" }};--text:{{ theme.text_color | default:"#7b4d3b" }};--muted:{{ theme.muted_color | default:"#a06b5b" }};--accent:{{ theme.accent_color | default:"#c2685d" }};--soft:{{ theme.secondary_accent_color | default:"#f0b4a5" }};--border:{{ theme.border_color | default:"#efc9bc" }};}
    @page{size:5in 7in;margin:0}
    *{box-sizing:border-box} body{margin:0;min-height:100vh;padding:24px;background:linear-gradient(180deg,#fff9f6 0%,var(--bg) 100%);font-family:var(--font);color:var(--text);display:flex;justify-content:center;align-items:flex-start}
    .card{width:5in;min-height:7in;margin:0;background:var(--paper);border:1px solid var(--border);border-radius:24px;padding:28px 22px;box-shadow:0 20px 48px rgba(163,103,85,.10)}
    .inner{border:1px solid rgba(239,201,188,.9);border-radius:18px;padding:28px 24px;text-align:center}
    .om{font-size:28px;color:var(--accent)}.eyebrow{font-size:13px;text-transform:uppercase;letter-spacing:.18em;color:var(--muted);margin-top:8px}
    .lotus{width:140px;height:90px;margin:18px auto 14px;position:relative}
    .petal{position:absolute;bottom:0;left:50%;transform-origin:bottom center;width:34px;height:56px;background:linear-gradient(180deg,var(--soft),rgba(240,180,165,.35));border-radius:60% 60% 6% 6%;border:1px solid rgba(194,104,93,.18)}
    .p1{transform:translateX(-50%) rotate(0deg)} .p2{transform:translateX(-50%) rotate(-26deg)} .p3{transform:translateX(-50%) rotate(26deg)} .p4{transform:translateX(-50%) rotate(-52deg);height:44px} .p5{transform:translateX(-50%) rotate(52deg);height:44px}
    .name{margin:0;font-family:var(--script);font-size:54px;line-height:1;color:var(--accent)} .join{font-size:28px;color:var(--muted);margin:8px 0}
    .message{max-width:460px;margin:16px auto 18px;font-size:19px;line-height:1.8;color:var(--muted)}
    .meta{display:grid;gap:12px;max-width:380px;margin:0 auto}
    .box{border:1px solid var(--border);border-radius:16px;padding:14px;background:rgba(255,255,255,.7)}
    .label{font-size:11px;text-transform:uppercase;letter-spacing:.18em;color:var(--muted);margin-bottom:6px}
    .value{font-size:18px;line-height:1.6}.footer{margin-top:16px;color:var(--muted);font-size:15px}
    @media (max-width:720px){.name{font-size:42px}}
  </style></head><body><div class="card"><div class="inner"><div class="om">ॐ</div><div class="eyebrow">{{ eyebrow }}</div><div class="lotus"><div class="petal p1"></div><div class="petal p2"></div><div class="petal p3"></div><div class="petal p4"></div><div class="petal p5"></div></div><p class="name">{{ couple.partner_one }}</p><div class="join">&amp;</div><p class="name">{{ couple.partner_two }}</p><div class="message">{{ message }}</div><div class="meta"><div class="box"><div class="label">Date</div><div class="value">{{ date_line }}</div></div><div class="box"><div class="label">Time and Venue</div><div class="value">{{ time_line }}<br>{{ venue_line }}</div></div></div><div class="footer">{{ footer_note }}</div></div></div><script data-preview-fit="true">
(function(){
  function boot(){
    const root = document.body && document.body.firstElementChild;
    if (!root || document.body.dataset.previewFitApplied) return;
    document.body.dataset.previewFitApplied = 'true';

    const style = document.createElement('style');
    style.textContent = [
      'html,body{height:100%;}',
      'body{overflow:hidden !important;padding:0 !important;display:block !important;min-height:100vh !important;}',
      '.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}',
      '.preview-stage{transform-origin:center center;will-change:transform;}',
      '@media (max-width:640px){.preview-shell{padding:12px;}}'
    ].join('');
    document.head.appendChild(style);

    const shell = document.createElement('div');
    shell.className = 'preview-shell';
    const stage = document.createElement('div');
    stage.className = 'preview-stage';

    document.body.insertBefore(shell, root);
    shell.appendChild(stage);
    stage.appendChild(root);

    function fit(){
      stage.style.transform = 'none';
      stage.style.width = 'auto';
      const bounds = root.getBoundingClientRect();
      const naturalWidth = Math.max(root.scrollWidth, root.offsetWidth, Math.ceil(bounds.width));
      const naturalHeight = Math.max(root.scrollHeight, root.offsetHeight, Math.ceil(bounds.height));
      const shellWidth = Math.max(shell.clientWidth - 24, 0);
      const shellHeight = Math.max(shell.clientHeight - 24, 0);
      const scale = Math.min(shellWidth / naturalWidth, shellHeight / naturalHeight, 1);
      stage.style.width = naturalWidth + 'px';
      stage.style.height = naturalHeight + 'px';
      stage.style.transform = 'scale(' + Math.max(scale * 0.96, 0.01) + ')';
    }

    requestAnimationFrame(() => requestAnimationFrame(fit));
    window.addEventListener('resize', fit);
    window.addEventListener('load', fit, { once: true });
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(fit).catch(() => {});
    }
    setTimeout(fit, 120);
    setTimeout(fit, 400);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot, { once: true });
  } else {
    boot();
  }
})();
</script>
</body></html>
