<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>
:root{--font:{{ theme.font_family | default:"'Cormorant Garamond','Georgia',serif" }};--script:{{ theme.script_font_family | default:"'Great Vibes','Segoe Script',cursive" }};--bg:{{ theme.bg_color | default:"#17193b" }};--paper:{{ theme.paper_color | default:"#1f224d" }};--text:{{ theme.text_color | default:"#f9eddb" }};--muted:{{ theme.muted_color | default:"#c8b7ff" }};--accent:{{ theme.accent_color | default:"#f5c76d" }};--soft:{{ theme.secondary_accent_color | default:"#3f4a8f" }};--border:{{ theme.border_color | default:"#3d4379" }};}
@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:24px;background:radial-gradient(circle at top,#2a2d63 0%,var(--bg) 58%,#10122f 100%);font-family:var(--font);color:var(--text);display:flex;justify-content:center;align-items:flex-start}.card{width:5in;min-height:7in;margin:0;background:linear-gradient(180deg,rgba(31,34,77,.98),rgba(20,22,54,.98));border:1px solid var(--border);border-radius:28px;padding:24px;box-shadow:0 28px 62px rgba(5,6,18,.38)}.inner{position:relative;height:100%;border:1px solid rgba(61,67,121,.9);border-radius:22px;padding:30px 26px 24px;overflow:hidden}.inner:before{content:"";position:absolute;inset:0;background-image:radial-gradient(circle at 20% 18%,rgba(245,199,109,.3) 0 2px,transparent 3px),radial-gradient(circle at 80% 28%,rgba(200,183,255,.25) 0 1.6px,transparent 2.6px),radial-gradient(circle at 56% 72%,rgba(245,199,109,.22) 0 1.4px,transparent 2.4px),radial-gradient(circle at 28% 84%,rgba(200,183,255,.22) 0 1.6px,transparent 2.6px)}.eyebrow,.host,.message,.venue,.foot{text-align:center;position:relative;z-index:1}.eyebrow{font-size:12px;letter-spacing:.28em;text-transform:uppercase;color:var(--accent)}.host{font-size:17px;color:var(--muted);margin:8px auto 18px;max-width:320px}.ring{width:90px;height:90px;margin:0 auto 16px;border-radius:50%;display:grid;place-items:center;border:1px solid rgba(245,199,109,.4);background:rgba(255,255,255,.02);position:relative;z-index:1}.ring:before,.ring:after{content:"";position:absolute;border-radius:50%;border:4px solid var(--accent);width:34px;height:34px}.ring:before{transform:translate(-10px,0)}.ring:after{border-color:rgba(200,183,255,.95);transform:translate(10px,10px)}.name{margin:0;text-align:center;font-size:48px;line-height:1.04;color:var(--text);position:relative;z-index:1}.join{text-align:center;color:var(--muted);letter-spacing:.24em;text-transform:uppercase;font-size:12px;margin:6px 0 8px;position:relative;z-index:1}.message{font-size:17px;line-height:1.6;max-width:340px;margin:14px auto 18px}.meta{display:grid;grid-template-columns:1fr 1fr;gap:12px;position:relative;z-index:1}.box{padding:14px 12px;border-radius:16px;border:1px solid rgba(61,67,121,.92);background:rgba(255,255,255,.03);text-align:center}.label{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);margin-bottom:7px}.value{font-size:16px;line-height:1.5}.venue{margin-top:14px;font-size:16px;line-height:1.55}.foot{margin-top:14px;font-size:14px;line-height:1.55;color:var(--muted)}
</style></head><body><div class="card"><div class="inner"><div class="eyebrow">{{ eyebrow }}</div><div class="host">{{ host_line }}</div><div class="ring"></div><p class="name">{{ couple.partner_one }}</p><div class="join">with</div><p class="name">{{ couple.partner_two }}</p><div class="message">{{ message }}</div><div class="meta"><div class="box"><div class="label">Date</div><div class="value">{{ date_line }}</div></div><div class="box"><div class="label">Time</div><div class="value">{{ time_line }}<br>{{ dress_code }}</div></div></div><div class="venue">{{ venue_name }}<br>{{ venue_address }}</div><div class="foot">{{ celebration_note }}<br>{{ footer_note }}</div></div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
