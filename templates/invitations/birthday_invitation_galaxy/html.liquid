<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>
:root{--font:{{ theme.font_family | default:"'Segoe UI',sans-serif" }};--display:{{ theme.display_font_family | default:"'Georgia',serif" }};--bg:{{ theme.bg_color | default:"#eef5ff" }};--paper:{{ theme.paper_color | default:"#ffffff" }};--text:{{ theme.text_color | default:"#2d3658" }};--muted:{{ theme.muted_color | default:"#7781a8" }};--accent:{{ theme.accent_color | default:"#8f7cff" }};--accent2:{{ theme.accent_two_color | default:"#39d6ff" }};--accent3:{{ theme.accent_three_color | default:"#ffd166" }};--border:{{ theme.border_color | default:"#d9e1ff" }};}
@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:20px;font-family:var(--font);background:var(--bg);color:var(--text);display:flex;justify-content:center;align-items:flex-start}.card{width:5in;min-height:7in;padding:22px;border-radius:28px;background:var(--paper);border:1px solid var(--border);box-shadow:0 18px 40px rgba(84,103,155,.1)}.orbit{width:126px;height:126px;margin:0 auto 14px;border-radius:50%;border:3px solid var(--accent2);display:grid;place-items:center;position:relative}.orbit:before,.orbit:after{content:"";position:absolute;border-radius:50%}.orbit:before{width:18px;height:18px;background:var(--accent);top:8px;right:18px}.orbit:after{width:14px;height:14px;background:var(--accent3);bottom:10px;left:18px}.center-star{font-family:var(--display);font-size:36px;color:var(--accent)}.eyebrow{text-align:center;font-size:12px;letter-spacing:.3em;text-transform:uppercase;color:var(--accent2)}.name{text-align:center;margin:0;font-family:var(--display);font-size:48px;line-height:1}.age{text-align:center;margin-top:8px;font-size:18px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted)}.host,.message{text-align:center}.host{margin:12px auto 0;max-width:320px;font-size:16px;line-height:1.6;color:var(--muted)}.message{margin:16px auto 0;padding:14px 16px;border-radius:18px;background:#fff;border:1px solid var(--border);font-size:15px;line-height:1.62;max-width:350px}.details{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:16px}.box{padding:13px;border-radius:16px;background:#fff;border:1px solid var(--border)}.box.wide{grid-column:1/-1}.label{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);margin-bottom:7px}.value{font-size:15px;line-height:1.5}.footer{margin-top:14px;text-align:center;font-size:14px;line-height:1.55;color:var(--muted)}
</style></head><body><div class="card"><div class="eyebrow">{{ eyebrow }}</div><div class="orbit"><div class="center-star">{{ age }}</div></div><p class="name">{{ honoree_name }}</p><div class="age">Orbit {{ age }}</div><div class="host">{{ host_line }}</div><div class="message">{{ message }}</div><div class="details"><div class="box"><div class="label">Date</div><div class="value">{{ date_line }}</div></div><div class="box"><div class="label">Time</div><div class="value">{{ time_line }}</div></div><div class="box wide"><div class="label">Launch Site</div><div class="value">{{ venue_name }}<br>{{ venue_address }}</div></div><div class="box"><div class="label">Look</div><div class="value">{{ dress_code }}</div></div><div class="box"><div class="label">RSVP</div><div class="value">{{ rsvp }}</div></div></div><div class="footer">{{ celebration_note }}</div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
