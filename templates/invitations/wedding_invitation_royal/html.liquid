<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>
:root{--font:{{ theme.font_family | default:"'Palatino Linotype','Book Antiqua',serif" }};--script:{{ theme.script_font_family | default:"'Lucida Handwriting','Brush Script MT',cursive" }};--bg:{{ theme.bg_color | default:"#1f1630" }};--paper:{{ theme.paper_color | default:"#fff8ef" }};--text:{{ theme.text_color | default:"#3f2434" }};--muted:{{ theme.muted_color | default:"#7b5b73" }};--accent:{{ theme.accent_color | default:"#7c2d5e" }};--gold:{{ theme.secondary_accent_color | default:"#d49b3d" }};--petal:{{ theme.petal_color | default:"#f3d7dc" }};--border:{{ theme.border_color | default:"#d7b78a" }};}
@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:24px;background:radial-gradient(circle at top left,rgba(212,155,61,.28),transparent 22%),radial-gradient(circle at bottom right,rgba(124,45,94,.33),transparent 26%),linear-gradient(160deg,#1d1328 0%,var(--bg) 58%,#2e173f 100%);display:flex;justify-content:center;align-items:flex-start;font-family:var(--font);color:var(--text)}.sheet{width:5in;min-height:7in;margin:0;padding:18px;border-radius:30px;background:linear-gradient(135deg,rgba(255,255,255,.1),rgba(255,255,255,.03)),rgba(255,255,255,.04);box-shadow:0 30px 80px rgba(6,3,15,.36)}.invitation{height:100%;position:relative;overflow:hidden;background:var(--paper);border:1px solid rgba(215,183,138,.85);border-radius:26px;padding:28px 24px 22px;box-shadow:inset 0 0 0 8px rgba(212,155,61,.08)}.invitation:before,.invitation:after{content:"";position:absolute;width:220px;height:220px;border-radius:50%;background:radial-gradient(circle,rgba(243,215,220,.8) 0 9%,transparent 10% 100%),radial-gradient(circle at 30% 30%,rgba(212,155,61,.16),transparent 60%),radial-gradient(circle at 70% 65%,rgba(124,45,94,.12),transparent 52%);opacity:.82}.invitation:before{top:-112px;left:-106px}.invitation:after{bottom:-120px;right:-104px}.seal{width:76px;height:76px;margin:0 auto 10px;border-radius:50%;display:grid;place-items:center;border:1px solid rgba(124,45,94,.22);background:radial-gradient(circle,rgba(255,255,255,.92) 0 42%,rgba(212,155,61,.35) 43% 56%,transparent 57%);color:var(--accent);letter-spacing:.24em;font-size:11px;text-transform:uppercase}.eyebrow,.invite-line,.message,.blessing,.footer-note{text-align:center}.eyebrow{color:var(--accent);letter-spacing:.28em;text-transform:uppercase;font-size:11px;margin-bottom:8px}.title{margin:0;text-align:center;font-size:21px;letter-spacing:.12em;text-transform:uppercase;color:var(--gold);font-weight:600}.names{margin:12px 0 10px;text-align:center}.name{font-family:var(--script);font-size:47px;line-height:1.02;color:var(--accent);margin:0;font-weight:400}.plus{color:var(--muted);text-transform:uppercase;letter-spacing:.22em;font-size:11px;margin:8px 0}.invite-line{color:var(--muted);font-style:italic;font-size:15px;line-height:1.45;margin-bottom:6px}.message{font-size:15px;line-height:1.52;margin:0 auto 8px;max-width:334px}.blessing{color:var(--gold);font-size:13px;line-height:1.45;margin-bottom:12px}.hero-panel{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:12px 0}.box{position:relative;border-radius:18px;padding:14px 14px 12px;border:1px solid rgba(215,183,138,.82);background:linear-gradient(180deg,rgba(255,255,255,.95),rgba(252,244,234,.96))}.box:before{content:"";position:absolute;inset:8px;border:1px dashed rgba(212,155,61,.3);border-radius:12px;pointer-events:none}.box h2{margin:0 0 8px;text-align:center;color:var(--accent);font-size:14px;letter-spacing:.06em;text-transform:uppercase;font-weight:600}.main-detail,.family{text-align:center;font-size:12px;line-height:1.45;padding:2px 6px}.highlights{list-style:none;margin:0;padding:0 2px;display:grid;gap:8px}.highlights li{position:relative;padding-left:18px;font-size:12px;line-height:1.42}.highlights li:before{content:"•";position:absolute;left:0;top:0;color:var(--gold);font-size:16px;line-height:1}.events{margin-top:8px;display:grid;gap:10px}.event{border:1px solid rgba(215,183,138,.8);border-radius:16px;padding:12px 14px;background:rgba(255,255,255,.72)}.event-name{color:var(--accent);font-size:15px;margin-bottom:3px;font-weight:600}.event-timing{color:var(--gold);text-transform:uppercase;letter-spacing:.08em;font-size:10px;line-height:1.45;margin-bottom:5px}.event-detail{font-size:12px;line-height:1.42}.footer-note{margin-top:12px;font-size:13px;line-height:1.48;color:var(--muted)}
</style></head><body><div class="sheet"><div class="invitation"><div class="seal">Wed</div><div class="eyebrow">{{ eyebrow | default: "Wedding Celebration" }}</div><h1 class="title">{{ title | default: "Wedding Celebration" }}</h1><div class="names"><p class="name">{{ couple.partner_one }}</p><div class="plus">and</div><p class="name">{{ couple.partner_two }}</p></div><div class="invite-line">{{ invited_by }}</div><div class="message">{{ message }}</div><div class="blessing">{{ blessing_line }}</div><div class="hero-panel"><div class="box"><h2>Wedding Details</h2><div class="main-detail">{{ wedding_day }}</div><div class="main-detail">{{ wedding_time }}</div><div class="main-detail">{{ wedding_venue }}</div><div class="main-detail">{{ wedding_address }}</div></div><div class="box"><h2>Decorative Highlights</h2><ul class="highlights">{% for item in highlights limit: 4 %}<li>{{ item }}</li>{% endfor %}</ul></div></div><div class="hero-panel"><div class="box"><h2>Host</h2><div class="family">{{ families.groom }}</div><div class="family">{{ families.bride }}</div></div><div class="box"><h2>Attire</h2><div class="family">{{ dress_code }}</div><div class="family">{{ rsvp.title }}</div></div></div><div class="events">{% for event in events limit: 2 %}<div class="event"><div class="event-name">{{ event.name }}</div><div class="event-timing">{{ event.timing }}</div><div class="event-detail">{{ event.description }}</div></div>{% endfor %}</div><div class="footer-note">{{ rsvp.contact_one }}<br>{{ rsvp.contact_two }}<br>{{ footer_note }}</div></div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
