<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>
:root{--font:{{ theme.font_family | default:"'Segoe UI',Arial,sans-serif" }};--display:{{ theme.display_font_family | default:"'Impact','Arial Black',sans-serif" }};--bg:{{ theme.bg_color | default:"#fff0fb" }};--paper:{{ theme.paper_color | default:"#ffffff" }};--text:{{ theme.text_color | default:"#32153c" }};--muted:{{ theme.muted_color | default:"#8f6a98" }};--accent:{{ theme.accent_color | default:"#ff2bd6" }};--accent2:{{ theme.accent_two_color | default:"#29f0ff" }};--accent3:{{ theme.accent_three_color | default:"#a8ff3e" }};--border:{{ theme.border_color | default:"#f6c7f2" }};}
@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:20px;font-family:var(--font);background:var(--bg);color:var(--text);display:flex;justify-content:center;align-items:flex-start}.card{width:5in;min-height:7in;border-radius:28px;padding:22px;background:var(--paper);border:2px solid var(--border);box-shadow:0 18px 40px rgba(115,54,115,.12)}.hero{border-radius:24px;padding:20px;background:linear-gradient(135deg,rgba(255,43,214,.14),rgba(41,240,255,.18),rgba(168,255,62,.14))}.eyebrow{display:inline-block;padding:7px 12px;border-radius:999px;background:#fff;font-size:11px;letter-spacing:.26em;text-transform:uppercase;color:var(--accent)}.name{margin:16px 0 0;font-family:var(--display);font-size:48px;line-height:.95;text-transform:uppercase}.age{margin-top:6px;font-size:54px;line-height:1;font-family:var(--display);color:var(--accent2)}.host{margin-top:10px;font-size:16px;line-height:1.58;color:var(--muted)}.message{margin-top:16px;padding:14px 16px;border-radius:18px;background:#fff;font-size:15px;line-height:1.6}.grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:16px}.box{padding:13px;border-radius:16px;background:#fff;border:1px solid var(--border)}.box.wide{grid-column:1/-1}.label{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);margin-bottom:7px}.value{font-size:15px;line-height:1.5}.footer{margin-top:14px;padding:13px 14px;border-radius:18px;background:rgba(41,240,255,.12);font-size:14px;line-height:1.55;color:var(--muted)}
</style></head><body><div class="card"><div class="hero"><div class="eyebrow">{{ eyebrow }}</div><p class="name">{{ honoree_name }}</p><div class="age">{{ age }}</div><div class="host">{{ host_line }}</div></div><div class="message">{{ message }}</div><div class="grid"><div class="box"><div class="label">Date</div><div class="value">{{ date_line }}</div></div><div class="box"><div class="label">Time</div><div class="value">{{ time_line }}</div></div><div class="box wide"><div class="label">Venue</div><div class="value">{{ venue_name }}<br>{{ venue_address }}</div></div><div class="box"><div class="label">Dress</div><div class="value">{{ dress_code }}</div></div><div class="box"><div class="label">RSVP</div><div class="value">{{ rsvp }}</div></div></div><div class="footer">{{ celebration_note }}</div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
