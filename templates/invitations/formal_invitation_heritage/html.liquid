<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>:root{--font:{{ theme.font_family | default:"'Tahoma',sans-serif" }};--display:{{ theme.display_font_family | default:"'Book Antiqua',Georgia,serif" }};--bg:{{ theme.bg_color | default:"#efe0d2" }};--paper:{{ theme.paper_color | default:"#fff8f0" }};--text:{{ theme.text_color | default:"#4a3227" }};--muted:{{ theme.muted_color | default:"#8a6a58" }};--accent:{{ theme.accent_color | default:"#a55233" }};--soft:{{ theme.secondary_accent_color | default:"#e6c4a8" }};--border:{{ theme.border_color | default:"#ddbea8" }};}@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:24px;background:linear-gradient(180deg,#f9f1ea 0%,var(--bg) 100%);display:flex;justify-content:center;align-items:flex-start;font-family:var(--font)}.card{width:5in;min-height:7in;border-radius:24px;overflow:hidden;background:var(--paper);border:1px solid var(--border);box-shadow:0 18px 44px rgba(120,83,59,.12)}.top,.bottom{padding:14px 22px;background:linear-gradient(90deg,rgba(165,82,51,.95),rgba(139,67,41,.95));color:#fff;text-align:center;font-size:11px;letter-spacing:.28em;text-transform:uppercase}.content{padding:24px 22px 22px;color:var(--text)}h1{margin:6px 0 10px;font-family:var(--display);font-size:31px;line-height:1.06;color:var(--accent);text-align:center}.occasion,.host,.message,.footer{text-align:center}.occasion{font-size:14px;line-height:1.58;color:var(--muted);max-width:306px;margin:0 auto 12px}.host,.message{font-size:14px;line-height:1.64;max-width:326px;margin:0 auto 12px}.details{margin:16px 0;padding:14px;border-radius:16px;background:rgba(230,196,168,.28);border:1px solid var(--border);text-align:center}.details .label{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--accent);margin-bottom:6px}.details .value{font-size:13px;line-height:1.54}.list{display:grid;gap:8px}.item{padding:10px 12px;border-left:3px solid var(--accent);background:#fff;border-radius:12px;font-size:12px;line-height:1.45}.footer{margin-top:14px;padding-top:12px;border-top:1px solid var(--border);font-size:12px;line-height:1.6;color:var(--muted)}</style></head><body><div class="card"><div class="top">{{ eyebrow }}</div><div class="content"><h1>{{ title }}</h1><div class="occasion">{{ occasion }}</div><div class="host">{{ host_line }}</div><div class="message">{{ message }}</div><div class="details"><div class="label">Event Details</div><div class="value">{{ date_line }}<br>{{ time_line }}<br>{{ venue_name }}<br>{{ venue_address }}</div></div><div class="list">{% for item in highlights limit:3 %}<div class="item">{{ item }}</div>{% endfor %}</div><div class="footer">{{ dress_code }}<br>{{ rsvp }}<br>{{ footer_note }}</div></div><div class="bottom">With compliments from the founding council</div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
