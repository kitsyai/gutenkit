<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>:root{--font:{{ theme.font_family | default:"'Helvetica Neue',Arial,sans-serif" }};--display:{{ theme.display_font_family | default:"'Times New Roman',serif" }};--bg:{{ theme.bg_color | default:"#e6ebef" }};--paper:{{ theme.paper_color | default:"#fcfcfb" }};--text:{{ theme.text_color | default:"#24303d" }};--muted:{{ theme.muted_color | default:"#66717d" }};--accent:{{ theme.accent_color | default:"#1f4b6e" }};--soft:{{ theme.secondary_accent_color | default:"#dbe4ea" }};--border:{{ theme.border_color | default:"#cfd9df" }};}@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:24px;background:linear-gradient(180deg,#f6f8fa 0%,var(--bg) 100%);display:flex;justify-content:center;align-items:flex-start;font-family:var(--font)}.card{width:5in;min-height:7in;padding:24px;border-radius:24px;background:var(--paper);color:var(--text);border:1px solid var(--border);box-shadow:0 18px 42px rgba(70,85,99,.12)}.hero{display:grid;grid-template-columns:1.2fr .8fr;gap:14px;align-items:start}.eyebrow{font-size:11px;letter-spacing:.3em;text-transform:uppercase;color:var(--accent)}h1{margin:10px 0 10px;font-family:var(--display);font-size:32px;line-height:1.02;text-transform:uppercase;color:var(--text)}.occasion{font-size:14px;line-height:1.6;color:var(--muted)}.tag{padding:16px;border-radius:18px;background:var(--soft);color:var(--accent);font-size:12px;line-height:1.55;text-transform:uppercase;letter-spacing:.14em}.host,.message{margin-top:14px;font-size:14px;line-height:1.66}.grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:18px 0}.box{padding:14px;border-radius:18px;border:1px solid var(--border);background:#fff}.box.wide{grid-column:1/-1}.label{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--accent);margin-bottom:7px}.value{font-size:13px;line-height:1.54}.footer{margin-top:12px;padding-top:12px;border-top:1px solid var(--border);font-size:12px;line-height:1.6;color:var(--muted)}</style></head><body><div class="card"><div class="hero"><div><div class="eyebrow">{{ eyebrow }}</div><h1>{{ title }}</h1><div class="occasion">{{ occasion }}</div></div><div class="tag">{{ dress_code }}<br><br>{{ footer_note }}</div></div><div class="host">{{ host_line }}</div><div class="message">{{ message }}</div><div class="grid"><div class="box"><div class="label">Date</div><div class="value">{{ date_line }}</div></div><div class="box"><div class="label">Time</div><div class="value">{{ time_line }}</div></div><div class="box wide"><div class="label">Venue</div><div class="value">{{ venue_name }}<br>{{ venue_address }}</div></div><div class="box wide"><div class="label">Highlights</div><div class="value">{% for item in highlights limit:3 %}{{ item }}{% unless forloop.last %}<br>{% endunless %}{% endfor %}</div></div></div><div class="footer">{{ rsvp }}</div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
