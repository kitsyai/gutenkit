<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>
:root{--font:{{ theme.font_family | default:"'Avenir Next','Segoe UI',sans-serif" }};--display:{{ theme.script_font_family | default:"'Playfair Display','Georgia',serif" }};--bg:{{ theme.bg_color | default:"#fff0e4" }};--paper:{{ theme.paper_color | default:"#fff7f0" }};--text:{{ theme.text_color | default:"#292126" }};--muted:{{ theme.muted_color | default:"#7d5e58" }};--accent:{{ theme.accent_color | default:"#ff7b54" }};--soft:{{ theme.secondary_accent_color | default:"#ffb26b" }};--border:{{ theme.border_color | default:"#f3ccb8" }};}
@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:24px;background:linear-gradient(180deg,#fff8f3 0%,var(--bg) 100%);font-family:var(--font);color:var(--text);display:flex;justify-content:center;align-items:flex-start}.card{width:5in;min-height:7in;margin:0;background:linear-gradient(180deg,#fffefb,#fff7f0);border:1px solid var(--border);border-radius:26px;padding:22px;box-shadow:0 22px 54px rgba(122,74,57,.1)}.hero{border-radius:22px;padding:24px;background:linear-gradient(140deg,rgba(255,123,84,.12),rgba(255,178,107,.18) 45%,rgba(255,255,255,.72));border:1px solid rgba(243,204,184,.9)}.eyebrow{font-size:11px;letter-spacing:.3em;text-transform:uppercase;color:var(--accent)}.host{margin-top:10px;font-size:17px;line-height:1.55;color:var(--muted);max-width:320px}.name{margin:18px 0 0;font-family:var(--display);font-size:52px;line-height:.98;color:var(--text)}.join{font-size:16px;letter-spacing:.24em;text-transform:uppercase;color:var(--accent);margin:10px 0}.message{font-size:17px;line-height:1.62;color:#514440;max-width:350px;margin-top:18px}.stack{display:grid;gap:12px;margin-top:16px}.row{display:grid;grid-template-columns:1fr 1fr;gap:12px}.box{padding:14px;border:1px solid var(--border);border-radius:18px;background:#fff}.label{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);margin-bottom:7px}.value{font-size:15px;line-height:1.48}.foot{padding:14px 16px;border-radius:18px;background:#fff1e8;border:1px solid rgba(255,178,107,.38);font-size:14px;line-height:1.55;color:var(--muted)}
</style></head><body><div class="card"><div class="hero"><div class="eyebrow">{{ eyebrow }}</div><div class="host">{{ host_line }}</div><p class="name">{{ couple.partner_one }}</p><div class="join">&amp;</div><p class="name">{{ couple.partner_two }}</p><div class="message">{{ message }}</div></div><div class="stack"><div class="row"><div class="box"><div class="label">Date</div><div class="value">{{ date_line }}</div></div><div class="box"><div class="label">Time</div><div class="value">{{ time_line }}<br>{{ dress_code }}</div></div></div><div class="box"><div class="label">Venue</div><div class="value">{{ venue_name }}<br>{{ venue_address }}</div></div><div class="foot">{{ celebration_note }}<br>{{ footer_note }}</div></div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
