<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>:root{--font:{{ theme.font_family | default:"'Georgia',serif" }};--display:{{ theme.display_font_family | default:"'Palatino Linotype','Book Antiqua',serif" }};--bg:{{ theme.bg_color | default:"#101828" }};--paper:{{ theme.paper_color | default:"#fbf7ef" }};--text:{{ theme.text_color | default:"#2d2430" }};--muted:{{ theme.muted_color | default:"#6f6171" }};--accent:{{ theme.accent_color | default:"#9f7a2f" }};--ink:{{ theme.secondary_accent_color | default:"#1d3557" }};--border:{{ theme.border_color | default:"#d9c79f" }};}@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:24px;background:radial-gradient(circle at top,rgba(159,122,47,.24),transparent 18%),linear-gradient(180deg,#0a1220 0%,var(--bg) 100%);display:flex;justify-content:center;align-items:flex-start;font-family:var(--font);color:var(--text)}.sheet{width:5in;min-height:7in;padding:18px;border-radius:28px;background:linear-gradient(135deg,rgba(255,255,255,.08),rgba(255,255,255,.02));box-shadow:0 30px 70px rgba(0,0,0,.35)}.card{position:relative;height:100%;padding:28px 26px 24px;border-radius:24px;background:var(--paper);border:1px solid rgba(217,199,159,.95);overflow:hidden;box-shadow:inset 0 0 0 8px rgba(159,122,47,.08)}.card:before,.card:after{content:"";position:absolute;inset:14px;border:1px solid rgba(159,122,47,.22);border-radius:18px;pointer-events:none}.seal{width:76px;height:76px;margin:0 auto 12px;border-radius:50%;display:grid;place-items:center;border:1px solid rgba(159,122,47,.6);color:var(--ink);font-size:12px;letter-spacing:.22em;text-transform:uppercase;background:radial-gradient(circle,rgba(255,255,255,.95) 0 52%,rgba(159,122,47,.18) 53% 100%)}.eyebrow,.occasion,.host,.message,.footer{text-align:center}.eyebrow{font-size:11px;letter-spacing:.3em;text-transform:uppercase;color:var(--accent)}h1{margin:4px 0 10px;text-align:center;font-family:var(--display);font-size:29px;line-height:1.15;color:var(--ink);text-transform:uppercase;letter-spacing:.08em}.occasion{font-size:14px;line-height:1.55;color:var(--muted);margin-bottom:12px}.host{font-size:15px;line-height:1.55;margin-bottom:10px}.message{font-size:14px;line-height:1.62;max-width:320px;margin:0 auto 14px}.meta{display:grid;gap:10px;margin:14px 0}.box{padding:12px 14px;border-radius:16px;border:1px solid rgba(217,199,159,.9);background:linear-gradient(180deg,rgba(255,255,255,.9),rgba(250,244,232,.9));text-align:center}.label{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--accent);margin-bottom:6px}.value{font-size:13px;line-height:1.52}.highlights{display:grid;gap:8px;margin:14px 0 12px}.item{padding:10px 12px;border-radius:14px;background:rgba(29,53,87,.05);font-size:12px;line-height:1.45;text-align:center}.footer{font-size:13px;line-height:1.55;color:var(--muted)}.footer strong{display:block;color:var(--ink);font-size:14px;margin-bottom:3px}</style></head><body><div class="sheet"><div class="card"><div class="seal">Gala</div><div class="eyebrow">{{ eyebrow }}</div><h1>{{ title }}</h1><div class="occasion">{{ occasion }}</div><div class="host">{{ host_line }}</div><div class="message">{{ message }}</div><div class="meta"><div class="box"><div class="label">Date and Time</div><div class="value">{{ date_line }}<br>{{ time_line }}</div></div><div class="box"><div class="label">Venue</div><div class="value">{{ venue_name }}<br>{{ venue_address }}</div></div></div><div class="highlights">{% for item in highlights limit:3 %}<div class="item">{{ item }}</div>{% endfor %}</div><div class="footer"><strong>{{ dress_code }}</strong>{{ rsvp }}<br>{{ footer_note }}</div></div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
