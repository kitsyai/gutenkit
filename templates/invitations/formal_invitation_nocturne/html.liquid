<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>:root{--font:{{ theme.font_family | default:"'Arial',sans-serif" }};--display:{{ theme.display_font_family | default:"'Bodoni MT',serif" }};--bg:{{ theme.bg_color | default:"#09131f" }};--paper:{{ theme.paper_color | default:"#111c2b" }};--text:{{ theme.text_color | default:"#f4eee4" }};--muted:{{ theme.muted_color | default:"#b8bfd0" }};--accent:{{ theme.accent_color | default:"#d4a24c" }};--sky:{{ theme.secondary_accent_color | default:"#60a5fa" }};--border:{{ theme.border_color | default:"#24334d" }};}@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:24px;background:radial-gradient(circle at top,rgba(96,165,250,.15),transparent 22%),linear-gradient(180deg,#060c15 0%,var(--bg) 100%);display:flex;justify-content:center;align-items:flex-start;font-family:var(--font)}.card{width:5in;min-height:7in;padding:26px;border-radius:24px;background:var(--paper);color:var(--text);border:1px solid var(--border);box-shadow:0 24px 60px rgba(0,0,0,.38);position:relative;overflow:hidden}.card:before{content:"";position:absolute;inset:14px;border:1px solid rgba(212,162,76,.18);border-radius:18px;pointer-events:none}.eyebrow{font-size:11px;letter-spacing:.3em;text-transform:uppercase;color:var(--sky)}h1{margin:10px 0 8px;font-family:var(--display);font-size:34px;line-height:1.02;text-transform:uppercase;color:var(--accent)}.occasion{font-size:14px;line-height:1.6;color:var(--muted);max-width:290px}.host,.message{font-size:14px;line-height:1.65;margin-top:12px}.bands{display:grid;gap:10px;margin:18px 0}.band{padding:12px 14px;border-left:3px solid var(--accent);background:rgba(255,255,255,.03);border-radius:12px}.band strong{display:block;font-size:10px;letter-spacing:.24em;text-transform:uppercase;color:var(--sky);margin-bottom:6px}.band span{font-size:13px;line-height:1.5}.footer{margin-top:16px;padding-top:12px;border-top:1px solid rgba(36,51,77,.9);font-size:12px;line-height:1.6;color:var(--muted)}</style></head><body><div class="card"><div class="eyebrow">{{ eyebrow }}</div><h1>{{ title }}</h1><div class="occasion">{{ occasion }}</div><div class="host">{{ host_line }}</div><div class="message">{{ message }}</div><div class="bands"><div class="band"><strong>Date and Time</strong><span>{{ date_line }}<br>{{ time_line }}</span></div><div class="band"><strong>Venue</strong><span>{{ venue_name }}<br>{{ venue_address }}</span></div>{% for item in highlights limit:3 %}<div class="band"><strong>Program {{ forloop.index }}</strong><span>{{ item }}</span></div>{% endfor %}</div><div class="footer">{{ dress_code }}<br>{{ rsvp }}<br>{{ footer_note }}</div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
