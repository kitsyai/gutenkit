<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>:root{--font:{{ theme.font_family | default:"'Verdana',sans-serif" }};--display:{{ theme.display_font_family | default:"'Didot','Bodoni MT',serif" }};--bg:{{ theme.bg_color | default:"#f1e4cf" }};--paper:{{ theme.paper_color | default:"#fff9f1" }};--text:{{ theme.text_color | default:"#4c3b21" }};--muted:{{ theme.muted_color | default:"#8a7350" }};--accent:{{ theme.accent_color | default:"#b58a3b" }};--deep:{{ theme.secondary_accent_color | default:"#6f4e37" }};--border:{{ theme.border_color | default:"#e5d2aa" }};}@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:24px;background:linear-gradient(180deg,#faf4e9 0%,var(--bg) 100%);display:flex;justify-content:center;align-items:flex-start;font-family:var(--font)}.card{width:5in;min-height:7in;padding:18px;border-radius:26px;background:rgba(255,255,255,.5);box-shadow:0 20px 44px rgba(134,105,54,.14)}.arch{height:100%;padding:24px 22px 22px;border-radius:22px 22px 18px 18px;background:var(--paper);border:1px solid var(--border);position:relative;overflow:hidden}.arch:before{content:"";position:absolute;left:32px;right:32px;top:16px;height:148px;border:1px solid rgba(181,138,59,.45);border-bottom:none;border-radius:160px 160px 0 0}.eyebrow{text-align:center;font-size:11px;letter-spacing:.28em;text-transform:uppercase;color:var(--accent);margin-top:12px}h1{margin:40px 0 8px;text-align:center;font-family:var(--display);font-size:31px;line-height:1.06;color:var(--deep)}.occasion,.host,.message,.footer{text-align:center}.occasion{font-size:14px;line-height:1.56;color:var(--muted);max-width:316px;margin:0 auto 12px}.host,.message{font-size:14px;line-height:1.62;max-width:326px;margin:0 auto 12px;color:var(--text)}.meta{display:grid;gap:10px;margin:16px 0}.panel{padding:12px 14px;border-radius:14px;border:1px solid rgba(229,210,170,.9);background:linear-gradient(180deg,#fff,rgba(245,232,204,.55));text-align:center}.label{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--accent);margin-bottom:6px}.value{font-size:13px;line-height:1.52}.items{display:grid;gap:8px}.item{padding:9px 12px;border-radius:999px;background:rgba(181,138,59,.1);font-size:12px;line-height:1.45;text-align:center}.footer{margin-top:14px;padding-top:12px;border-top:1px solid var(--border);font-size:12px;line-height:1.6;color:var(--muted)}</style></head><body><div class="card"><div class="arch"><div class="eyebrow">{{ eyebrow }}</div><h1>{{ title }}</h1><div class="occasion">{{ occasion }}</div><div class="host">{{ host_line }}</div><div class="message">{{ message }}</div><div class="meta"><div class="panel"><div class="label">Date and Time</div><div class="value">{{ date_line }}<br>{{ time_line }}</div></div><div class="panel"><div class="label">Venue</div><div class="value">{{ venue_name }}<br>{{ venue_address }}</div></div></div><div class="items">{% for item in highlights limit:3 %}<div class="item">{{ item }}</div>{% endfor %}</div><div class="footer">{{ dress_code }}<br>{{ rsvp }}<br>{{ footer_note }}</div></div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
