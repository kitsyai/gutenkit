<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>:root{--font:{{ theme.font_family | default:"'Cambria',serif" }};--display:{{ theme.display_font_family | default:"'Times New Roman',serif" }};--bg:{{ theme.bg_color | default:"#14342d" }};--paper:{{ theme.paper_color | default:"#f8f4ec" }};--text:{{ theme.text_color | default:"#22312b" }};--muted:{{ theme.muted_color | default:"#5a746c" }};--accent:{{ theme.accent_color | default:"#1f6b57" }};--gold:{{ theme.secondary_accent_color | default:"#c6a96a" }};--border:{{ theme.border_color | default:"#d2c7ae" }};}@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:24px;background:linear-gradient(160deg,#0b211d 0%,var(--bg) 100%);display:flex;justify-content:center;align-items:flex-start;font-family:var(--font)}.card{width:5in;min-height:7in;padding:18px;border-radius:26px;background:rgba(255,255,255,.06);box-shadow:0 24px 60px rgba(0,0,0,.32)}.frame{height:100%;border-radius:22px;background:var(--paper);overflow:hidden;border:1px solid rgba(210,199,174,.95);display:grid;grid-template-columns:1.08fr .92fr}.left{padding:28px 22px 24px}.right{padding:24px 18px;background:linear-gradient(180deg,rgba(31,107,87,.08),rgba(198,169,106,.12));border-left:1px solid rgba(210,199,174,.95)}.eyebrow{font-size:11px;letter-spacing:.28em;text-transform:uppercase;color:var(--accent)}h1{margin:10px 0 8px;font-family:var(--display);font-size:31px;line-height:1.06;color:var(--accent)}.occasion{font-size:14px;line-height:1.58;color:var(--muted)}.host,.message{margin-top:12px;font-size:14px;line-height:1.62;color:var(--text)}.venue{margin-top:18px;padding:14px;border-radius:16px;border:1px solid var(--border);background:#fff}.label{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);margin-bottom:7px}.value{font-size:13px;line-height:1.54;color:var(--text)}.program{display:grid;gap:10px}.entry{padding:12px;border-radius:16px;background:rgba(255,255,255,.78);border:1px solid rgba(210,199,174,.8)}.entry strong{display:block;font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--accent);margin-bottom:5px}.entry span{font-size:12px;line-height:1.45;color:var(--text)}.footer{margin-top:16px;padding-top:12px;border-top:1px solid var(--border);font-size:12px;line-height:1.6;color:var(--muted)}</style></head><body><div class="card"><div class="frame"><div class="left"><div class="eyebrow">{{ eyebrow }}</div><h1>{{ title }}</h1><div class="occasion">{{ occasion }}</div><div class="host">{{ host_line }}</div><div class="message">{{ message }}</div><div class="venue"><div class="label">Reception Details</div><div class="value">{{ date_line }}<br>{{ time_line }}<br>{{ venue_name }}<br>{{ venue_address }}</div></div><div class="footer">{{ dress_code }}<br>{{ rsvp }}<br>{{ footer_note }}</div></div><div class="right"><div class="label">Featured Program</div><div class="program">{% for item in highlights limit:3 %}<div class="entry"><strong>Highlight {{ forloop.index }}</strong><span>{{ item }}</span></div>{% endfor %}</div></div></div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
