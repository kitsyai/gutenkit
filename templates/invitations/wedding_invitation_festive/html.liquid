<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
:root{
      --font: {{ theme.font_family | default: "'Cormorant Garamond', 'Georgia', serif" }};
      --script-font: {{ theme.script_font_family | default: "'Great Vibes', 'Segoe Script', cursive" }};
      --bg: {{ theme.bg_color | default: "#fdf2e3" }};
      --paper: {{ theme.paper_color | default: "#fffaf2" }};
      --text: {{ theme.text_color | default: "#5a3426" }};
      --muted: {{ theme.muted_color | default: "#9d6d4f" }};
      --accent: {{ theme.accent_color | default: "#b36a22" }};
      --accent-2: {{ theme.secondary_accent_color | default: "#d99b47" }};
      --rose: {{ theme.rose_color | default: "#e7c3d1" }};
      --lotus: {{ theme.lotus_color | default: "#ee9db1" }};
      --border: {{ theme.border_color | default: "#efc78c" }};
      --line: {{ theme.line_color | default: "#d4a35e" }};
    }
    @page{size:5in 7in;margin:0}
    *{box-sizing:border-box}
    body{
      margin:0;
      min-height:100vh;
      padding:24px;
      display:flex;
      justify-content:center;
      align-items:flex-start;
      background:
        radial-gradient(circle at top left, rgba(217,155,71,0.12), transparent 18%),
        radial-gradient(circle at top right, rgba(238,157,177,0.14), transparent 22%),
        linear-gradient(180deg, #fff7ee 0%, var(--bg) 100%);
      color:var(--text);
      font-family:var(--font);
    }
    .sheet{
      width:5in;
      min-height:7in;
      margin:0;
      background:var(--paper);
      border:1px solid var(--border);
      border-radius:28px;
      padding:18px;
      box-shadow:0 26px 72px rgba(143, 96, 43, 0.11);
    }
    .card{
      position:relative;
      overflow:hidden;
      border:2px solid rgba(239,199,140,0.88);
      border-radius:24px;
      padding:28px 26px 24px;
      background:
        radial-gradient(circle at top center, rgba(255,255,255,0.92), rgba(255,249,241,0.98)),
        linear-gradient(180deg, rgba(217,155,71,0.05), transparent 34%);
    }
    .card:before{
      content:"";
      position:absolute;
      inset:10px;
      border:1px dashed rgba(211,163,94,0.28);
      border-radius:18px;
      pointer-events:none;
    }
    .pattern{
      position:absolute;
      inset:0;
      background-image:
        radial-gradient(circle at 20px 20px, rgba(217,155,71,0.06) 0 2px, transparent 3px),
        radial-gradient(circle at 60px 60px, rgba(211,163,94,0.05) 0 2px, transparent 3px);
      background-size:80px 80px;
      opacity:0.55;
      pointer-events:none;
    }
    .arch-wrap{
      position:relative;
      z-index:1;
      padding:10px 16px 0;
    }
    .arch{
      position:relative;
      padding:34px 32px 24px;
      border:2px solid rgba(239,199,140,0.86);
      border-bottom-left-radius:18px;
      border-bottom-right-radius:18px;
      border-top-left-radius:280px;
      border-top-right-radius:280px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.94), rgba(255,248,238,0.98)),
        radial-gradient(circle at top, rgba(217,155,71,0.12), transparent 46%);
      text-align:center;
    }
    .arch:before{
      content:"";
      position:absolute;
      inset:12px;
      border:1px solid rgba(211,163,94,0.30);
      border-bottom-left-radius:12px;
      border-bottom-right-radius:12px;
      border-top-left-radius:240px;
      border-top-right-radius:240px;
      pointer-events:none;
    }
    .sacred{
      color:var(--accent);
      font-size:22px;
      letter-spacing:0.08em;
      text-transform:uppercase;
      margin-bottom:8px;
      font-weight:700;
    }
    .eyebrow{
      color:var(--muted);
      font-size:14px;
      letter-spacing:0.14em;
      text-transform:uppercase;
      margin-bottom:10px;
    }
    .host{
      color:var(--muted);
      font-size:17px;
      line-height:1.7;
      max-width:460px;
      margin:0 auto 12px;
    }
    .name{
      margin:0;
      font-family:var(--script-font);
      color:var(--accent);
      font-size:60px;
      line-height:0.98;
      font-weight:400;
    }
    .join{
      color:var(--accent-2);
      font-size:34px;
      margin:6px 0;
      font-family:var(--script-font);
    }
    .lamp{
      position:absolute;
      top:24px;
      width:54px;
      height:132px;
      color:var(--accent-2);
    }
    .lamp.left{left:6px}
    .lamp.right{right:6px}
    .lamp svg{width:100%;height:100%;display:block}
    .details{
      position:relative;
      z-index:1;
      margin:22px auto 18px;
      max-width:540px;
      text-align:center;
    }
    .month{
      color:var(--accent);
      font-size:18px;
      letter-spacing:0.22em;
      text-transform:uppercase;
      margin-bottom:4px;
    }
    .date-row{
      display:flex;
      align-items:flex-end;
      justify-content:center;
      gap:14px;
      margin-bottom:10px;
    }
    .weekday,
    .time{
      font-size:14px;
      letter-spacing:0.16em;
      text-transform:uppercase;
      color:var(--muted);
      border-bottom:1px solid rgba(211,163,94,0.38);
      padding-bottom:4px;
      min-width:92px;
    }
    .day{
      font-size:64px;
      line-height:0.9;
      color:var(--accent);
      font-weight:700;
    }
    .year{
      color:var(--muted);
      font-size:17px;
      letter-spacing:0.12em;
      text-transform:uppercase;
      margin-bottom:14px;
    }
    .venue{
      font-size:20px;
      color:var(--text);
      margin-bottom:4px;
    }
    .venue-address{
      font-size:16px;
      color:var(--muted);
    }
    .divider{
      width:160px;
      height:1px;
      margin:18px auto;
      background:linear-gradient(90deg, transparent, var(--line), transparent);
      position:relative;
    }
    .divider:before,
    .divider:after{
      content:"";
      position:absolute;
      top:-4px;
      width:10px;
      height:10px;
      border-radius:50%;
      background:rgba(217,155,71,0.4);
    }
    .divider:before{left:36px}
    .divider:after{right:36px}
    .bottom{
      position:relative;
      z-index:1;
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:18px;
      align-items:end;
    }
    .panel{
      border:1px solid rgba(239,199,140,0.84);
      border-radius:20px;
      padding:18px 18px 16px;
      background:rgba(255,255,255,0.72);
      min-height:160px;
    }
    .panel h2{
      margin:0 0 10px;
      text-align:center;
      color:var(--accent);
      text-transform:uppercase;
      letter-spacing:0.10em;
      font-size:16px;
    }
    .panel p{
      margin:0 0 8px;
      text-align:center;
      font-size:16px;
      line-height:1.7;
      color:var(--muted);
    }
    .floral{
      position:relative;
      height:170px;
      border-radius:20px;
      overflow:hidden;
      background:
        radial-gradient(circle at 22% 82%, rgba(238,157,177,0.22), transparent 26%),
        radial-gradient(circle at 78% 82%, rgba(238,157,177,0.22), transparent 26%),
        linear-gradient(180deg, transparent 0%, rgba(217,155,71,0.05) 100%);
    }
    .flower{
      position:absolute;
      bottom:0;
      width:124px;
      height:124px;
    }
    .flower.left{left:6px}
    .flower.right{right:6px;transform:scaleX(-1)}
    .flower svg{width:100%;height:100%;display:block}
    .footer{
      position:relative;
      z-index:1;
      text-align:center;
      margin-top:16px;
      color:var(--muted);
      font-size:15px;
      line-height:1.8;
    }
    @media (max-width: 720px){
      .arch{padding:30px 18px 20px}
      .name{font-size:44px}
      .bottom{grid-template-columns:1fr}
      .date-row{gap:8px}
      .weekday,.time{min-width:auto;font-size:12px}
      .day{font-size:48px}
      .lamp{display:none}
    }
  </style>
</head>
<body>
  <div class="sheet">
    <div class="card">
      <div class="pattern"></div>

      <div class="arch-wrap">
        <div class="lamp left">
          <svg viewBox="0 0 60 140" aria-hidden="true">
            <path d="M30 0 V28" stroke="#d99b47" stroke-width="2"/>
            <path d="M20 30 H40" stroke="#d99b47" stroke-width="2"/>
            <path d="M18 34 C22 48, 38 48, 42 34" fill="none" stroke="#d99b47" stroke-width="2"/>
            <path d="M18 44 H42 V82 C42 92, 34 100, 30 102 C26 100, 18 92, 18 82 Z" fill="#f6d3a3" stroke="#d99b47" stroke-width="2"/>
            <path d="M24 54 H36" stroke="#b36a22" stroke-width="2"/>
            <path d="M24 64 H36" stroke="#b36a22" stroke-width="2"/>
            <path d="M30 102 V120" stroke="#d99b47" stroke-width="2"/>
            <path d="M24 120 H36" stroke="#d99b47" stroke-width="2"/>
          </svg>
        </div>
        <div class="lamp right">
          <svg viewBox="0 0 60 140" aria-hidden="true">
            <path d="M30 0 V28" stroke="#d99b47" stroke-width="2"/>
            <path d="M20 30 H40" stroke="#d99b47" stroke-width="2"/>
            <path d="M18 34 C22 48, 38 48, 42 34" fill="none" stroke="#d99b47" stroke-width="2"/>
            <path d="M18 44 H42 V82 C42 92, 34 100, 30 102 C26 100, 18 92, 18 82 Z" fill="#f6d3a3" stroke="#d99b47" stroke-width="2"/>
            <path d="M24 54 H36" stroke="#b36a22" stroke-width="2"/>
            <path d="M24 64 H36" stroke="#b36a22" stroke-width="2"/>
            <path d="M30 102 V120" stroke="#d99b47" stroke-width="2"/>
            <path d="M24 120 H36" stroke="#d99b47" stroke-width="2"/>
          </svg>
        </div>

        <div class="arch">
          <div class="sacred">{{ sacred_mark | default: "Om" }}</div>
          <div class="eyebrow">{{ eyebrow | default: "Together with their families" }}</div>
          <div class="host">{{ host_line | default: "cordially invite you to join the occasion of their joyous commitment" }}</div>
          <p class="name">{{ couple.partner_one | default: "Prerna Singh" }}</p>
          <div class="join">&amp;</div>
          <p class="name">{{ couple.partner_two | default: "Sumit Gupta" }}</p>
        </div>
      </div>

      <div class="details">
        <div class="month">{{ date_month | default: "July" }}</div>
        <div class="date-row">
          <div class="weekday">{{ weekday | default: "Sunday" }}</div>
          <div class="day">{{ date_day | default: "28" }}</div>
          <div class="time">{{ time_line | default: "At 8 AM" }}</div>
        </div>
        <div class="year">{{ date_year | default: "2026" }}</div>
        <div class="venue">{{ venue_name | default: "123 Anywhere Street" }}</div>
        <div class="venue-address">{{ venue_address | default: "Any City, ST 12345" }}</div>
      </div>

      <div class="divider"></div>

      <div class="bottom">
        <div class="panel">
          <h2>With Blessings</h2>
          {% for line in family_lines %}
          <p>{{ line }}</p>
          {% endfor %}
        </div>
        <div class="floral">
          <div class="flower left">
            <svg viewBox="0 0 120 120" aria-hidden="true">
              <g>
                <ellipse cx="30" cy="92" rx="10" ry="22" fill="#8bb07d" transform="rotate(-24 30 92)"/>
                <ellipse cx="50" cy="86" rx="10" ry="24" fill="#8bb07d" transform="rotate(-6 50 86)"/>
                <ellipse cx="68" cy="94" rx="10" ry="22" fill="#8bb07d" transform="rotate(16 68 94)"/>
                <circle cx="42" cy="68" r="20" fill="#f3d0da"/>
                <circle cx="62" cy="56" r="18" fill="#efb3c3"/>
                <circle cx="78" cy="72" r="16" fill="#f5dbe2"/>
                <circle cx="58" cy="74" r="9" fill="#d99b47"/>
                <ellipse cx="94" cy="86" rx="12" ry="18" fill="#f0a9ba"/>
                <ellipse cx="24" cy="74" rx="12" ry="18" fill="#efc4d0"/>
              </g>
            </svg>
          </div>
          <div class="flower right">
            <svg viewBox="0 0 120 120" aria-hidden="true">
              <g>
                <ellipse cx="30" cy="92" rx="10" ry="22" fill="#8bb07d" transform="rotate(-24 30 92)"/>
                <ellipse cx="50" cy="86" rx="10" ry="24" fill="#8bb07d" transform="rotate(-6 50 86)"/>
                <ellipse cx="68" cy="94" rx="10" ry="22" fill="#8bb07d" transform="rotate(16 68 94)"/>
                <circle cx="42" cy="68" r="20" fill="#f3d0da"/>
                <circle cx="62" cy="56" r="18" fill="#efb3c3"/>
                <circle cx="78" cy="72" r="16" fill="#f5dbe2"/>
                <circle cx="58" cy="74" r="9" fill="#d99b47"/>
                <ellipse cx="94" cy="86" rx="12" ry="18" fill="#f0a9ba"/>
                <ellipse cx="24" cy="74" rx="12" ry="18" fill="#efc4d0"/>
              </g>
            </svg>
          </div>
        </div>
      </div>

      <div class="footer">
        <div>{{ footer_note | default: "Kindly RSVP before 17th June" }}</div>
        <div>{{ rsvp_phone | default: "01-234-456-7890" }}</div>
      </div>
    <script data-preview-fit="true">
(function(){
  function boot(){
    const root = document.body && document.body.firstElementChild;
    if (!root || document.body.dataset.previewFitApplied) return;
    document.body.dataset.previewFitApplied = 'true';

    const style = document.createElement('style');
    style.textContent = [
      'html,body{height:100%;}',
      'body{overflow:hidden !important;padding:0 !important;display:block !important;min-height:100vh !important;}',
      '.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}',
      '.preview-stage{transform-origin:center center;will-change:transform;}',
      '@media (max-width:640px){.preview-shell{padding:12px;}}'
    ].join('');
    document.head.appendChild(style);

    const shell = document.createElement('div');
    shell.className = 'preview-shell';
    const stage = document.createElement('div');
    stage.className = 'preview-stage';

    document.body.insertBefore(shell, root);
    shell.appendChild(stage);
    stage.appendChild(root);

    function fit(){
      stage.style.transform = 'none';
      stage.style.width = 'auto';
      const bounds = root.getBoundingClientRect();
      const naturalWidth = Math.max(root.scrollWidth, root.offsetWidth, Math.ceil(bounds.width));
      const naturalHeight = Math.max(root.scrollHeight, root.offsetHeight, Math.ceil(bounds.height));
      const shellWidth = Math.max(shell.clientWidth - 24, 0);
      const shellHeight = Math.max(shell.clientHeight - 24, 0);
      const scale = Math.min(shellWidth / naturalWidth, shellHeight / naturalHeight, 1);
      stage.style.width = naturalWidth + 'px';
      stage.style.height = naturalHeight + 'px';
      stage.style.transform = 'scale(' + Math.max(scale * 0.96, 0.01) + ')';
    }

    requestAnimationFrame(() => requestAnimationFrame(fit));
    window.addEventListener('resize', fit);
    window.addEventListener('load', fit, { once: true });
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(fit).catch(() => {});
    }
    setTimeout(fit, 120);
    setTimeout(fit, 400);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot, { once: true });
  } else {
    boot();
  }
})();
</script>
</body>
</html>
