<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>
:root{--font:{{ theme.font_family | default:"'Georgia','Times New Roman',serif" }};--script:{{ theme.script_font_family | default:"'Brush Script MT','Lucida Handwriting',cursive" }};--bg:{{ theme.bg_color | default:"#f8f1e7" }};--paper:{{ theme.paper_color | default:"#fffaf4" }};--text:{{ theme.text_color | default:"#4a2f2a" }};--muted:{{ theme.muted_color | default:"#8b6b61" }};--accent:{{ theme.accent_color | default:"#a63d40" }};--soft:{{ theme.accent_soft_color | default:"#e8c9a7" }};--border:{{ theme.border_color | default:"#d6b184" }};}
@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:24px;background:radial-gradient(circle at top left,rgba(166,61,64,.08),transparent 22%),radial-gradient(circle at top right,rgba(214,177,132,.16),transparent 20%),linear-gradient(180deg,#fcf7f0 0%,var(--bg) 100%);color:var(--text);font-family:var(--font);display:flex;justify-content:center;align-items:flex-start}.frame{width:5in;min-height:7in;margin:0;background:var(--paper);border:1px solid var(--border);border-radius:28px;padding:18px;box-shadow:0 24px 60px rgba(92,51,37,.12)}.card{height:100%;position:relative;border:2px solid rgba(214,177,132,.7);border-radius:22px;padding:28px 24px 22px;overflow:hidden;background:linear-gradient(180deg,rgba(255,255,255,.86),rgba(255,248,240,.96))}.card:before,.card:after{content:"";position:absolute;width:180px;height:180px;border-radius:50%;background:radial-gradient(circle,rgba(166,61,64,.10) 0 10%,transparent 11%),radial-gradient(circle at 30% 30%,rgba(214,177,132,.2),transparent 55%)}.card:before{top:-100px;left:-92px}.card:after{right:-100px;bottom:-96px}.crest{width:72px;height:72px;margin:0 auto 10px;border-radius:50%;display:grid;place-items:center;border:1px solid rgba(166,61,64,.22);background:radial-gradient(circle,rgba(255,255,255,.95) 0 42%,rgba(232,201,167,.56) 43% 54%,transparent 55%);color:var(--accent);font-size:11px;letter-spacing:.22em;text-transform:uppercase}.kicker,.host,.message,.closing{text-align:center}.kicker{color:var(--accent);letter-spacing:.24em;text-transform:uppercase;font-size:11px}.host{color:var(--muted);font-size:16px;line-height:1.45;margin:8px auto 12px;max-width:320px;font-style:italic}.names{margin-bottom:12px}.name{margin:0;text-align:center;font-size:48px;line-height:1;color:var(--accent);font-family:var(--script);font-weight:400}.and{text-align:center;color:var(--muted);letter-spacing:.22em;text-transform:uppercase;font-size:11px;margin:8px 0}.message{font-size:16px;line-height:1.55;max-width:332px;margin:0 auto 16px}.details{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}.detail-card{border:1px solid rgba(214,177,132,.78);border-radius:16px;padding:12px 10px;background:rgba(255,255,255,.74);text-align:center}.detail-label{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);margin-bottom:6px}.detail-value{font-size:14px;line-height:1.4}.family-grid,.footer-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-top:12px}.panel{border:1px solid rgba(214,177,132,.72);border-radius:16px;padding:12px;background:rgba(255,252,247,.92)}.panel h2{margin:0 0 8px;color:var(--accent);font-size:15px;text-align:center;font-weight:600}.family-line,.rsvp-line{font-size:12px;line-height:1.45;text-align:center}.events{margin-top:12px;border:1px solid rgba(214,177,132,.72);border-radius:18px;padding:14px;background:linear-gradient(180deg,rgba(255,255,255,.92),rgba(250,243,234,.94))}.events h2{margin:0 0 10px;text-align:center;color:var(--accent);font-size:17px;font-weight:600}.event-list{display:grid;gap:8px}.event{display:grid;grid-template-columns:92px 1fr;gap:10px;align-items:start;padding-top:8px;border-top:1px solid rgba(214,177,132,.4)}.event:first-child{border-top:0;padding-top:0}.event-name{color:var(--accent);font-size:13px;font-weight:700}.event-meta{color:var(--muted);font-size:10px;letter-spacing:.05em;text-transform:uppercase;line-height:1.45;margin-top:3px}.event-detail{font-size:12px;line-height:1.45}.dress{margin-top:10px;text-align:center;font-size:12px;line-height:1.45;color:var(--muted)}.closing{margin-top:12px;font-size:13px;line-height:1.5;color:var(--muted)}
</style></head><body><div class="frame"><div class="card"><div class="crest">Wed</div><div class="kicker">{{ title | default: "Wedding Invitation" }}</div><div class="host">{{ host_line }}</div><div class="names"><p class="name">{{ couple.partner_one }}</p><div class="and">and</div><p class="name">{{ couple.partner_two }}</p></div><div class="message">{{ invitation_message }}</div><div class="details"><div class="detail-card"><div class="detail-label">Date</div><div class="detail-value">{{ date_line }}</div></div><div class="detail-card"><div class="detail-label">Time</div><div class="detail-value">{{ time_line }}</div></div><div class="detail-card"><div class="detail-label">Venue</div><div class="detail-value">{{ venue_name }}</div></div></div><div class="family-grid"><div class="panel"><h2>Families</h2><div class="family-line">{{ families.partner_one_side }}</div></div><div class="panel"><h2>Blessings</h2><div class="family-line">{{ families.partner_two_side }}</div></div></div><div class="events"><h2>Ceremony Schedule</h2><div class="event-list">{% for event in events limit: 3 %}<div class="event"><div><div class="event-name">{{ event.name }}</div><div class="event-meta">{{ event.day }}<br>{{ event.date }}<br>{{ event.time }}</div></div><div class="event-detail">{{ event.detail }}</div></div>{% endfor %}</div><div class="dress">{{ dress_code }}</div></div><div class="footer-grid"><div class="panel"><h2>RSVP</h2><div class="rsvp-line">{{ rsvp.primary_name }} | {{ rsvp.primary_phone }}</div><div class="rsvp-line">{{ rsvp.secondary_name }} | {{ rsvp.secondary_phone }}</div></div><div class="panel"><h2>Venue</h2><div class="rsvp-line">{{ venue_address }}</div></div></div><div class="closing">{{ closing_note }}</div></div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
