<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>
:root{--font:{{ theme.font_family | default: "'Cormorant Garamond', 'Georgia', serif" }};--display:{{ theme.script_font_family | default: "'Cinzel Decorative', 'Georgia', serif" }};--bg:{{ theme.bg_color | default:"#120f23" }};--paper:{{ theme.paper_color | default:"#1d1636" }};--text:{{ theme.text_color | default:"#f4e9d8" }};--muted:{{ theme.muted_color | default:"#c4b29b" }};--accent:{{ theme.accent_color | default:"#d6ac59" }};--soft:{{ theme.secondary_accent_color | default:"#6d5ba7" }};--border:{{ theme.border_color | default:"#3b2d68" }};}
    @page{size:5in 7in;margin:0}
    *{box-sizing:border-box} body{margin:0;min-height:100vh;padding:24px;background:radial-gradient(circle at top,#2f2356 0%,var(--bg) 58%);font-family:var(--font);color:var(--text);display:flex;justify-content:center;align-items:flex-start}
    .card{width:5in;min-height:7in;margin:0;padding:20px;background:rgba(255,255,255,.03);border-radius:28px;box-shadow:0 30px 70px rgba(0,0,0,.34)}
    .inner{position:relative;background:var(--paper);border:1px solid var(--border);border-radius:22px;padding:34px 28px 28px;overflow:hidden}
    .inner:before{content:"";position:absolute;inset:0;background-image:radial-gradient(circle at 20% 20%,rgba(214,172,89,.22) 0 1px,transparent 2px),radial-gradient(circle at 70% 35%,rgba(244,233,216,.12) 0 1px,transparent 2px),radial-gradient(circle at 50% 80%,rgba(214,172,89,.18) 0 1px,transparent 2px);background-size:120px 120px;opacity:.75}
    .top{position:relative;z-index:1;text-align:center}
    .eyebrow{color:var(--accent);letter-spacing:.28em;text-transform:uppercase;font-size:12px}
    .crest{width:96px;height:96px;border-radius:50%;margin:18px auto;border:1px solid rgba(214,172,89,.46);display:grid;place-items:center;box-shadow:inset 0 0 0 8px rgba(109,91,167,.18);font-size:28px;color:var(--accent)}
    .name{margin:0;font-family:var(--display);font-size:44px;color:var(--text);line-height:1.1}
    .join{margin:8px 0;color:var(--accent);letter-spacing:.18em;text-transform:uppercase;font-size:12px}
    .message{max-width:520px;margin:16px auto 20px;text-align:center;font-size:20px;line-height:1.7;color:var(--muted)}
    .details{display:grid;grid-template-columns:1fr 1fr;gap:16px;position:relative;z-index:1}
    .detail{border:1px solid rgba(59,45,104,.9);border-radius:18px;padding:18px;text-align:center;background:rgba(255,255,255,.02)}
    .label{font-size:11px;color:var(--accent);text-transform:uppercase;letter-spacing:.18em;margin-bottom:8px}
    .value{font-size:20px;line-height:1.6}
    .footer{margin-top:18px;text-align:center;color:var(--muted);font-size:16px;position:relative;z-index:1}
    @media (max-width:720px){.details{grid-template-columns:1fr}.name{font-size:34px}}
  </style></head><body><div class="card"><div class="inner"><div class="top"><div class="eyebrow">{{ eyebrow }}</div><div class="crest">✦</div><p class="name">{{ couple.partner_one }}</p><div class="join">with</div><p class="name">{{ couple.partner_two }}</p><div class="message">{{ message }}</div></div><div class="details"><div class="detail"><div class="label">Date and Time</div><div class="value">{{ date_line }}<br>{{ time_line }}</div></div><div class="detail"><div class="label">Venue</div><div class="value">{{ venue_name }}<br><span style="font-size:15px;color:var(--muted)">{{ venue_address }}</span></div></div></div><div class="footer">{{ footer_note }}</div></div></div><script data-preview-fit="true">
(function(){
  function boot(){
    const root = document.body && document.body.firstElementChild;
    if (!root || document.body.dataset.previewFitApplied) return;
    document.body.dataset.previewFitApplied = 'true';

    const style = document.createElement('style');
    style.textContent = [
      'html,body{height:100%;}',
      'body{overflow:hidden !important;padding:0 !important;display:block !important;min-height:100vh !important;}',
      '.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}',
      '.preview-stage{transform-origin:center center;will-change:transform;}',
      '@media (max-width:640px){.preview-shell{padding:12px;}}'
    ].join('');
    document.head.appendChild(style);

    const shell = document.createElement('div');
    shell.className = 'preview-shell';
    const stage = document.createElement('div');
    stage.className = 'preview-stage';

    document.body.insertBefore(shell, root);
    shell.appendChild(stage);
    stage.appendChild(root);

    function fit(){
      stage.style.transform = 'none';
      stage.style.width = 'auto';
      const bounds = root.getBoundingClientRect();
      const naturalWidth = Math.max(root.scrollWidth, root.offsetWidth, Math.ceil(bounds.width));
      const naturalHeight = Math.max(root.scrollHeight, root.offsetHeight, Math.ceil(bounds.height));
      const shellWidth = Math.max(shell.clientWidth - 24, 0);
      const shellHeight = Math.max(shell.clientHeight - 24, 0);
      const scale = Math.min(shellWidth / naturalWidth, shellHeight / naturalHeight, 1);
      stage.style.width = naturalWidth + 'px';
      stage.style.height = naturalHeight + 'px';
      stage.style.transform = 'scale(' + Math.max(scale * 0.96, 0.01) + ')';
    }

    requestAnimationFrame(() => requestAnimationFrame(fit));
    window.addEventListener('resize', fit);
    window.addEventListener('load', fit, { once: true });
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(fit).catch(() => {});
    }
    setTimeout(fit, 120);
    setTimeout(fit, 400);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot, { once: true });
  } else {
    boot();
  }
})();
</script>
</body></html>
