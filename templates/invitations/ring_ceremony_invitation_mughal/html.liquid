<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>
:root{--font:{{ theme.font_family | default:"'Georgia','Times New Roman',serif" }};--script:{{ theme.script_font_family | default:"'Lucida Handwriting','Segoe Script',cursive" }};--bg:{{ theme.bg_color | default:"#f7ebe8" }};--paper:{{ theme.paper_color | default:"#fff7f3" }};--text:{{ theme.text_color | default:"#6a2f32" }};--muted:{{ theme.muted_color | default:"#9d6b57" }};--accent:{{ theme.accent_color | default:"#a63c42" }};--gold:{{ theme.secondary_accent_color | default:"#d7a66d" }};--border:{{ theme.border_color | default:"#e5c4a6" }};}
@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:24px;background:linear-gradient(180deg,#fffaf6 0%,var(--bg) 100%);font-family:var(--font);color:var(--text);display:flex;justify-content:center;align-items:flex-start}.card{width:5in;min-height:7in;margin:0;background:var(--paper);border:1px solid var(--border);border-radius:26px;padding:14px;box-shadow:0 24px 58px rgba(118,63,66,.12)}.inner{height:100%;border:2px solid rgba(215,166,109,.55);border-radius:20px;padding:26px 22px 22px;position:relative;overflow:hidden}.inner:before,.inner:after{content:"";position:absolute;top:18px;bottom:18px;width:36px;background:linear-gradient(180deg,rgba(215,166,109,.16),transparent);border-left:1px solid rgba(215,166,109,.3);border-right:1px solid rgba(215,166,109,.3)}.inner:before{left:16px}.inner:after{right:16px}.arch{max-width:320px;margin:0 auto;padding:30px 18px 18px;border:1px solid rgba(229,196,166,.92);border-top-left-radius:210px;border-top-right-radius:210px;border-bottom-left-radius:14px;border-bottom-right-radius:14px;background:linear-gradient(180deg,#fffdfb,#fff6ee)}.eyebrow,.host,.message,.venue,.foot{text-align:center}.eyebrow{font-size:12px;letter-spacing:.24em;text-transform:uppercase;color:var(--muted)}.host{font-size:16px;color:var(--accent);margin:8px 0 14px}.name{margin:0;text-align:center;font-family:var(--script);font-size:46px;line-height:1.06;color:var(--accent)}.join{text-align:center;font-size:14px;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);margin:8px 0}.message{font-size:16px;line-height:1.58;max-width:340px;margin:16px auto}.meta{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:16px}.box{padding:12px;border:1px solid var(--border);border-radius:14px;background:rgba(255,255,255,.74);text-align:center}.label{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:7px}.value{font-size:15px;line-height:1.45}.venue{margin-top:12px;font-size:16px;line-height:1.55}.foot{margin-top:14px;font-size:14px;line-height:1.55;color:var(--muted)}
</style></head><body><div class="card"><div class="inner"><div class="eyebrow">{{ eyebrow }}</div><div class="host">{{ host_line }}</div><div class="arch"><p class="name">{{ couple.partner_one }}</p><div class="join">and</div><p class="name">{{ couple.partner_two }}</p></div><div class="message">{{ message }}</div><div class="meta"><div class="box"><div class="label">Date</div><div class="value">{{ date_line }}</div></div><div class="box"><div class="label">Time</div><div class="value">{{ time_line }}<br>{{ dress_code }}</div></div></div><div class="venue">{{ venue_name }}<br>{{ venue_address }}</div><div class="foot">{{ celebration_note }}<br>{{ footer_note }}</div></div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
