<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>
:root{--font:{{ theme.font_family | default:"'Tahoma',sans-serif" }};--display:{{ theme.display_font_family | default:"'Arial Black',sans-serif" }};--bg:{{ theme.bg_color | default:"#fff3e7" }};--paper:{{ theme.paper_color | default:"#fffaf4" }};--text:{{ theme.text_color | default:"#4d2b2a" }};--muted:{{ theme.muted_color | default:"#8f5d54" }};--accent:{{ theme.accent_color | default:"#ef476f" }};--accent2:{{ theme.accent_two_color | default:"#ffd166" }};--accent3:{{ theme.accent_three_color | default:"#118ab2" }};--border:{{ theme.border_color | default:"#f1d2c4" }};}
@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:20px;background:var(--bg);font-family:var(--font);color:var(--text);display:flex;justify-content:center;align-items:flex-start}.card{overflow:hidden;width:5in;min-height:7in;border-radius:26px;background:var(--paper);border:1px solid var(--border);box-shadow:0 18px 40px rgba(153,91,79,.12)}.hero{padding:22px;background:repeating-linear-gradient(90deg,var(--accent) 0 20px,#fff 20px 40px,var(--accent2) 40px 60px,#fff 60px 80px,var(--accent3) 80px 100px,#fff 100px 120px)}.badge{width:88px;height:88px;margin:0 auto 12px;border-radius:50%;display:grid;place-items:center;background:#fff;border:5px solid var(--accent2);font-family:var(--display);font-size:32px;color:var(--accent)}.eyebrow{text-align:center;font-size:12px;letter-spacing:.26em;text-transform:uppercase;color:#fff}.name{text-align:center;margin:10px 0 0;font-family:var(--display);font-size:42px;line-height:1;color:#fff}.host{text-align:center;margin:12px auto 0;max-width:320px;font-size:16px;line-height:1.6;color:#fff}.body{padding:20px 22px 22px}.message{padding:14px 16px;border-radius:18px;background:#fff;font-size:15px;line-height:1.62}.details{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:16px}.box{padding:13px;border-radius:16px;background:#fff;border:1px solid var(--border)}.box.wide{grid-column:1/-1}.label{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);margin-bottom:7px}.value{font-size:15px;line-height:1.5}.footer{margin-top:14px;padding:12px 14px;border-radius:16px;background:rgba(255,209,102,.2);font-size:14px;line-height:1.55;color:var(--muted)}
</style></head><body><div class="card"><div class="hero"><div class="badge">{{ age }}</div><div class="eyebrow">{{ eyebrow }}</div><p class="name">{{ honoree_name }}</p><div class="host">{{ host_line }}</div></div><div class="body"><div class="message">{{ message }}</div><div class="details"><div class="box"><div class="label">Date</div><div class="value">{{ date_line }}</div></div><div class="box"><div class="label">Time</div><div class="value">{{ time_line }}</div></div><div class="box wide"><div class="label">Venue</div><div class="value">{{ venue_name }}<br>{{ venue_address }}</div></div><div class="box"><div class="label">Dress</div><div class="value">{{ dress_code }}</div></div><div class="box"><div class="label">RSVP</div><div class="value">{{ rsvp }}</div></div></div><div class="footer">{{ celebration_note }}</div></div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
