<!doctype html>
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>
:root{--font:{{ theme.font_family | default:"'Arial',sans-serif" }};--display:{{ theme.display_font_family | default:"'Georgia',serif" }};--bg:{{ theme.bg_color | default:"#f7f1dd" }};--paper:{{ theme.paper_color | default:"#fffdf8" }};--text:{{ theme.text_color | default:"#3c4332" }};--muted:{{ theme.muted_color | default:"#6d7558" }};--accent:{{ theme.accent_color | default:"#d75b4d" }};--accent2:{{ theme.accent_two_color | default:"#7ab55c" }};--accent3:{{ theme.accent_three_color | default:"#f2d27a" }};--border:{{ theme.border_color | default:"#e7ddc0" }};}
@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:20px;background:linear-gradient(180deg,#fffef8 0%,var(--bg) 100%);font-family:var(--font);color:var(--text);display:flex;justify-content:center;align-items:flex-start}.card{overflow:hidden;width:5in;min-height:7in;border-radius:26px;border:1px solid var(--border);background:
linear-gradient(0deg,rgba(255,255,255,.76),rgba(255,255,255,.76)),
linear-gradient(90deg,rgba(215,91,77,.16) 0 12.5%,transparent 12.5% 25%,rgba(215,91,77,.16) 25% 37.5%,transparent 37.5% 50%,rgba(215,91,77,.16) 50% 62.5%,transparent 62.5% 75%,rgba(215,91,77,.16) 75% 87.5%,transparent 87.5% 100%),
linear-gradient(rgba(215,91,77,.16) 0 12.5%,transparent 12.5% 25%,rgba(215,91,77,.16) 25% 37.5%,transparent 37.5% 50%,rgba(215,91,77,.16) 50% 62.5%,transparent 62.5% 75%,rgba(215,91,77,.16) 75% 87.5%,transparent 87.5% 100%);
background-size:100% 100%,64px 64px,64px 64px;box-shadow:0 20px 46px rgba(120,98,65,.14)}.top{padding:22px 22px 12px}.eyebrow{display:inline-block;padding:8px 12px;border-radius:999px;background:rgba(122,181,92,.14);font-size:11px;letter-spacing:.28em;text-transform:uppercase;color:var(--accent2)}.name{margin:18px 0 0;font-family:var(--display);font-size:46px;line-height:1;color:var(--text)}.age{margin-top:8px;font-size:19px;color:var(--accent);letter-spacing:.2em;text-transform:uppercase}.host{margin-top:12px;font-size:16px;line-height:1.62;color:var(--muted);max-width:310px}.polaroids{display:grid;grid-template-columns:1fr 1fr;gap:12px;padding:0 22px;margin-top:8px}.photo{padding:10px;background:#fff;box-shadow:0 10px 18px rgba(0,0,0,.08)}.photo.tilt-left{transform:rotate(-4deg)}.photo.tilt-right{transform:rotate(3deg)}.photo-box{height:88px;border-radius:8px;background:linear-gradient(135deg,rgba(122,181,92,.3),rgba(242,210,122,.7));display:flex;align-items:center;justify-content:center;font-size:28px}.photo-note{margin-top:10px;font-size:13px;color:var(--muted);text-align:center}.details{display:grid;gap:12px;padding:18px 22px 22px}.row{display:grid;grid-template-columns:1fr 1fr;gap:12px}.box{padding:13px 14px;border-radius:16px;background:rgba(255,255,255,.86);border:1px solid var(--border)}.label{font-size:10px;letter-spacing:.24em;text-transform:uppercase;color:var(--muted);margin-bottom:7px}.value{font-size:15px;line-height:1.52}.footer{padding:12px 14px;border-radius:16px;background:rgba(122,181,92,.1);font-size:14px;line-height:1.55;color:var(--muted)}
</style></head><body><div class="card"><div class="top"><div class="eyebrow">{{ eyebrow }}</div><p class="name">{{ honoree_name }}</p><div class="age">Turns {{ age }}</div><div class="host">{{ host_line }}</div></div><div class="polaroids"><div class="photo tilt-left"><div class="photo-box">Sun</div><div class="photo-note">{{ message }}</div></div><div class="photo tilt-right"><div class="photo-box">Cake</div><div class="photo-note">{{ celebration_note }}</div></div></div><div class="details"><div class="row"><div class="box"><div class="label">Date</div><div class="value">{{ date_line }}</div></div><div class="box"><div class="label">Time</div><div class="value">{{ time_line }}</div></div></div><div class="box"><div class="label">Venue</div><div class="value">{{ venue_name }}<br>{{ venue_address }}</div></div><div class="row"><div class="box"><div class="label">Dress</div><div class="value">{{ dress_code }}</div></div><div class="box"><div class="label">RSVP</div><div class="value">{{ rsvp }}</div></div></div></div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
