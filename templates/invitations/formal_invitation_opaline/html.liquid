<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><style>:root{--font:{{ theme.font_family | default:"'Trebuchet MS','Segoe UI',sans-serif" }};--display:{{ theme.display_font_family | default:"'Garamond',serif" }};--bg:{{ theme.bg_color | default:"#f5ece7" }};--paper:{{ theme.paper_color | default:"#fffaf8" }};--text:{{ theme.text_color | default:"#4b3441" }};--muted:{{ theme.muted_color | default:"#8c6f7a" }};--accent:{{ theme.accent_color | default:"#b76e79" }};--soft:{{ theme.secondary_accent_color | default:"#f1d8d8" }};--border:{{ theme.border_color | default:"#e9cfd3" }};}@page{size:5in 7in;margin:0}*{box-sizing:border-box}body{margin:0;min-height:100vh;padding:24px;background:linear-gradient(180deg,#fbf5f2 0%,var(--bg) 100%);display:flex;justify-content:center;align-items:flex-start;font-family:var(--font);color:var(--text)}.card{width:5in;min-height:7in;border-radius:24px;overflow:hidden;border:1px solid var(--border);background:var(--paper);box-shadow:0 18px 42px rgba(122,84,95,.12);display:grid;grid-template-columns:84px 1fr}.ribbon{background:linear-gradient(180deg,var(--accent),#c98993);color:#fff;padding:24px 14px;display:flex;align-items:center;justify-content:center;text-align:center}.ribbon span{font-size:11px;letter-spacing:.28em;text-transform:uppercase;writing-mode:vertical-rl;transform:rotate(180deg)}.content{padding:26px 24px 24px;position:relative}.content:before{content:"";position:absolute;top:18px;right:18px;width:92px;height:92px;border-radius:50%;background:radial-gradient(circle,rgba(183,110,121,.14) 0 18%,transparent 19%),radial-gradient(circle at 35% 35%,rgba(183,110,121,.18),transparent 58%)}.eyebrow{font-size:11px;letter-spacing:.28em;text-transform:uppercase;color:var(--accent)}h1{margin:8px 0 8px;font-family:var(--display);font-size:30px;line-height:1.08;color:#553646}.occasion{font-size:14px;line-height:1.55;color:var(--muted);max-width:280px}.host,.message{font-size:14px;line-height:1.62;margin-top:12px}.panels{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:18px 0}.panel{padding:14px;border-radius:18px;background:linear-gradient(180deg,#fff,rgba(241,216,216,.45));border:1px solid var(--border)}.label{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--accent);margin-bottom:8px}.value{font-size:13px;line-height:1.5}.highlights{list-style:none;margin:0;padding:0;display:grid;gap:8px}.highlights li{padding:9px 10px;border-radius:12px;background:rgba(183,110,121,.08);font-size:12px;line-height:1.45}.footer{margin-top:14px;padding-top:12px;border-top:1px solid var(--border);font-size:13px;line-height:1.55;color:var(--muted)}</style></head><body><div class="card"><div class="ribbon"><span>{{ eyebrow }}</span></div><div class="content"><div class="eyebrow">{{ title }}</div><h1>{{ occasion }}</h1><div class="host">{{ host_line }}</div><div class="message">{{ message }}</div><div class="panels"><div class="panel"><div class="label">Date and Time</div><div class="value">{{ date_line }}<br>{{ time_line }}</div></div><div class="panel"><div class="label">Venue</div><div class="value">{{ venue_name }}<br>{{ venue_address }}</div></div></div><div class="panel"><div class="label">Event Features</div><ul class="highlights">{% for item in highlights limit:3 %}<li>{{ item }}</li>{% endfor %}</ul></div><div class="footer">{{ dress_code }}<br>{{ rsvp }}<br>{{ footer_note }}</div></div></div><script data-preview-fit="true">(function(){function b(){const r=document.body&&document.body.firstElementChild;if(!r||document.body.dataset.previewFitApplied)return;document.body.dataset.previewFitApplied='true';const s=document.createElement('style');s.textContent='html,body{height:100%;}body{overflow:hidden!important;padding:0!important;display:block!important;min-height:100vh!important;}.preview-shell{width:100vw;height:100vh;display:flex;justify-content:center;align-items:center;padding:20px;overflow:hidden;background:inherit;}.preview-stage{transform-origin:center center;will-change:transform;}@media (max-width:640px){.preview-shell{padding:12px;}}';document.head.appendChild(s);const sh=document.createElement('div');sh.className='preview-shell';const st=document.createElement('div');st.className='preview-stage';document.body.insertBefore(sh,r);sh.appendChild(st);st.appendChild(r);function f(){st.style.transform='none';st.style.width='auto';const bd=r.getBoundingClientRect();const w=Math.max(r.scrollWidth,r.offsetWidth,Math.ceil(bd.width));const h=Math.max(r.scrollHeight,r.offsetHeight,Math.ceil(bd.height));const sw=Math.max(sh.clientWidth-24,0);const shh=Math.max(sh.clientHeight-24,0);const sc=Math.min(sw/w,shh/h,1);st.style.width=w+'px';st.style.height=h+'px';st.style.transform='scale('+Math.max(sc*.96,.01)+')';}requestAnimationFrame(()=>requestAnimationFrame(f));window.addEventListener('resize',f);window.addEventListener('load',f,{once:true});if(document.fonts&&document.fonts.ready){document.fonts.ready.then(f).catch(()=>{});}setTimeout(f,120);setTimeout(f,400);}if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',b,{once:true});}else{b();}})();</script></body></html>
