<!doctype html>
<html lang="en"><head><meta charset="utf-8"><style>
  :root{
    --font: {{ theme.font_family | default: "Arial, Helvetica, sans-serif" }};
    --accent: {{ theme.accent_color | default: "#10b981" }};
    --text: {{ theme.text_color | default: "#111827" }};
    --muted: {{ theme.muted_color | default: "#6b7280" }};
    --bg: {{ theme.bg_color | default: "#f4f7fb" }};
    --card: {{ theme.card_color | default: "#ffffff" }};
  }
  body{margin:0;background:var(--bg);font-family:var(--font);color:var(--text);}
  .wrap{max-width:520px;margin:0 auto;padding:32px 16px;}
  .card{background:var(--card);border:1px solid #e5e7eb;border-radius:14px;padding:30px;}
  .brand{font-size:12px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);}
  h1{font-size:22px;margin:8px 0 6px;}
  p{font-size:15px;line-height:1.6;}
  .muted{color:var(--muted);}
  .btn{display:inline-block;margin:18px 0;background:var(--accent);color:#ffffff;text-decoration:none;padding:12px 22px;border-radius:10px;font-weight:700;}
  .footer{color:var(--muted);font-size:11px;margin-top:16px;text-align:center;}
</style></head>
<body><div class="wrap"><div class="card">
  {% if brand_name %}<div class="brand">{{ brand_name | escape }}</div>{% endif %}
  <h1>{{ heading | default: "Welcome aboard" }}{% if name %}, {{ name | escape }}{% endif %}!</h1>
  <p>{{ body | default: "Your account is ready. We're glad to have you." }}</p>
  {% if action_url %}<p><a class="btn" href="{{ action_url | escape }}">{{ action_label | default: "Get started" }}</a></p>{% endif %}
  <p class="muted">{{ closing | default: "Need help? Just reply to this email." }}</p>
  {{ slots.footer }}
</div>
<div class="footer">{{ footer_text | default: brand_name }}</div>
</div></body></html>
