<!doctype html>
<html lang="en"><head><meta charset="utf-8"><style>
  :root{
    --font: {{ theme.font_family | default: "Arial, Helvetica, sans-serif" }};
    --accent: {{ theme.accent_color | default: "#4f46e5" }};
    --text: {{ theme.text_color | default: "#111827" }};
    --muted: {{ theme.muted_color | default: "#6b7280" }};
    --bg: {{ theme.bg_color | default: "#f4f7fb" }};
    --card: {{ theme.card_color | default: "#ffffff" }};
  }
  body{margin:0;background:var(--bg);font-family:var(--font);color:var(--text);}
  .wrap{max-width:480px;margin:0 auto;padding:32px 16px;}
  .card{background:var(--card);border:1px solid #e5e7eb;border-radius:14px;padding:28px;}
  .brand{font-size:12px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);}
  h1{font-size:20px;margin:8px 0 4px;}
  .muted{color:var(--muted);font-size:13px;line-height:1.5;}
  .code{font-size:34px;font-weight:700;letter-spacing:.28em;color:var(--accent);margin:22px 0;}
  .footer{color:var(--muted);font-size:11px;margin-top:16px;text-align:center;}
</style></head>
<body><div class="wrap"><div class="card">
  {% if brand_name %}<div class="brand">{{ brand_name | escape }}</div>{% endif %}
  <h1>{{ heading | default: "Your verification code" }}</h1>
  <p class="muted">Use this code to {{ purpose | default: "verify your account" }}. It expires in {{ ttl_minutes | default: 10 }} minutes.</p>
  <div class="code">{{ code }}</div>
  <p class="muted">Didn't request this? You can safely ignore this email.</p>
  {{ slots.footer }}
</div>
<div class="footer">{{ footer_text | default: brand_name }}</div>
</div></body></html>
