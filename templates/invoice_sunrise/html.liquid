<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<style>
  :root {
    --font: {{ theme.font_family | default: "'Averta Std', 'Trebuchet MS', sans-serif" }};
    --accent: {{ theme.accent_color | default: "#ea580c" }};
    --highlight: {{ theme.highlight_color | default: "#f59e0b" }};
    --soft: {{ theme.accent_soft | default: "#ffedd5" }};
    --rule: {{ theme.rule_color | default: "#fed7aa" }};
    --ink: {{ theme.text_color | default: "#431407" }};
  }
  @page { size: {{ theme.page_size | default: "A4" }}; margin: {{ theme.page_margin | default: "14mm" }}; }
  * { box-sizing: border-box; }
  body { margin: 0; font: 10px/1.5 var(--font); color: var(--ink); }
  .hero {
    padding: 18px 20px;
    border-radius: 24px;
    background: linear-gradient(135deg, #fff7ed, var(--soft) 42%, #fff);
    border: 1px solid var(--rule);
  }
  .hero .row, .metrics, .party-grid, .totals .r, .pay .r { display: flex; justify-content: space-between; gap: 14px; }
  .hero .row { align-items: flex-start; }
  .eyebrow { color: var(--accent); text-transform: uppercase; letter-spacing: 0.14em; font-size: 9px; font-weight: 700; }
  h1 { margin: 4px 0 6px; font-size: 28px; line-height: 0.96; }
  .stamp { min-width: 240px; background: #fff; border-radius: 18px; padding: 12px 14px; border: 1px solid var(--rule); }
  .stamp .line { display: flex; justify-content: space-between; padding: 3px 0; }
  .metrics { margin-top: 14px; }
  .metric { flex: 1; background: linear-gradient(180deg, #fff, #fff7ed); border: 1px solid var(--rule); border-radius: 16px; padding: 12px 14px; }
  .metric .k { color: #9a3412; text-transform: uppercase; font-size: 8px; letter-spacing: 0.12em; }
  .metric .v { margin-top: 5px; font-size: 18px; font-weight: 700; }
  .section { margin-top: 14px; padding: 14px 16px; border-radius: 22px; border: 1px solid var(--rule); }
  .section h2 { margin: 0 0 10px; color: var(--accent); font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; }
  .party-grid .card { flex: 1; background: #fffaf5; border: 1px solid var(--rule); border-radius: 16px; padding: 12px; }
  .line { margin: 2px 0; }
  table { width: 100%; border-collapse: collapse; }
  th, td { padding: 9px 7px; border-bottom: 1px solid var(--rule); text-align: right; vertical-align: top; }
  th { font-size: 8px; color: #9a3412; text-transform: uppercase; letter-spacing: 0.12em; }
  th:first-child, td:first-child { text-align: left; width: 28%; }
  .split { margin-top: 14px; display: flex; justify-content: space-between; gap: 18px; }
  .copy { flex: 1; background: #fffaf5; border-radius: 18px; padding: 14px 16px; }
  .totals { width: 280px; background: linear-gradient(180deg, var(--accent), #c2410c); color: #fff; border-radius: 20px; padding: 14px 16px; }
  .totals .r { padding: 4px 0; }
  .grand { margin-top: 8px; padding-top: 10px; border-top: 2px solid rgba(255,255,255,0.32); font-size: 12px; font-weight: 700; }
  .pay { margin-top: 12px; }
  .pay .r { padding: 5px 0; border-bottom: 1px dashed var(--rule); }
  .footer { margin-top: 16px; color: #7c2d12; font-size: 9px; }
</style>
</head>
<body>
  <div class="hero">
    <div class="row">
      <div>
        <div class="eyebrow">{{ supplier.legal_name | escape }}</div>
        <h1>{{ invoice.title | default: "Tax Invoice" }}</h1>
        {% for l in supplier.address_lines %}<div>{{ l | escape }}</div>{% endfor %}
      </div>
      <div class="stamp">
        <div class="line"><span>Invoice No.</span><strong>{{ invoice.number }}</strong></div>
        <div class="line"><span>Date</span><strong>{{ invoice.date }}</strong></div>
        <div class="line"><span>Order</span><strong>{{ order.number }}</strong></div>
        {% if invoice.place_of_supply %}<div class="line"><span>Place</span><strong>{{ invoice.place_of_supply }}</strong></div>{% endif %}
        <div class="line"><span>GSTIN</span><strong>{{ supplier.gstin }}</strong></div>
      </div>
    </div>
    <div class="metrics">
      <div class="metric"><div class="k">Invoice total</div><div class="v">{{ totals_summary.total }}</div></div>
      <div class="metric"><div class="k">Amount paid</div><div class="v">{{ totals_summary.paid }}</div></div>
      <div class="metric"><div class="k">Balance due</div><div class="v">{{ totals_summary.balance }}</div></div>
    </div>
  </div>

  <div class="section">
    <h2>Parties</h2>
    <div class="party-grid">
      <div class="card">
        <div class="line"><strong>Bill to</strong></div>
        <div class="line">{{ bill_to.name | escape }}</div>
        {% if bill_to.org %}<div class="line">{{ bill_to.org | escape }}</div>{% endif %}
        {% for l in bill_to.lines %}<div class="line">{{ l | escape }}</div>{% endfor %}
      </div>
      <div class="card">
        <div class="line"><strong>Ship to</strong></div>
        <div class="line">{{ ship_to.name | escape }}</div>
        {% if ship_to.org %}<div class="line">{{ ship_to.org | escape }}</div>{% endif %}
        {% for l in ship_to.lines %}<div class="line">{{ l | escape }}</div>{% endfor %}
      </div>
      <div class="card">
        <div class="line"><strong>Supplier IDs</strong></div>
        {% if supplier.pan %}<div class="line">PAN {{ supplier.pan }}</div>{% endif %}
        {% if supplier.cin %}<div class="line">CIN {{ supplier.cin }}</div>{% endif %}
        {% if invoice.state_code %}<div class="line">State {{ invoice.state_code }}</div>{% endif %}
        {% if invoice.document_ref %}<div class="line">Ref {{ invoice.document_ref }}</div>{% endif %}
      </div>
    </div>
  </div>

  <div class="section">
    <h2>Items</h2>
    <table>
      <thead>
        <tr><th>Description</th><th>SAC</th><th>Qty</th><th>Duration</th><th>Listed</th><th>Discount</th><th>Taxable</th><th>GST</th><th>Total</th></tr>
      </thead>
      <tbody>
        {% for it in items %}
        <tr>
          <td>{{ it.description | escape }}</td>
          <td>{{ it.sac }}</td><td>{{ it.qty }}</td><td>{{ it.duration }}</td><td>{{ it.listed }}</td><td>{{ it.discount }}</td><td>{{ it.taxable }}</td><td>{{ it.gst }}</td><td><strong>{{ it.total }}</strong></td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <div class="split">
    <div class="copy">
      <strong>Payment acknowledgement</strong>
      {% if payment.acknowledgement %}<div style="margin-top:8px;">{{ payment.acknowledgement | escape }}</div>{% endif %}
      {% if payment %}
      <div class="pay">
        {% for r in payment.rows %}
        <div class="r"><span>{{ r.lk }}: {{ r.lv }}</span><span>{{ r.rk }}: {{ r.rv }}</span></div>
        {% endfor %}
      </div>
      {% endif %}
    </div>
    <div class="totals">
      {% for t in totals %}<div class="r"><span>{{ t.label }}</span><span>{{ t.value }}</span></div>{% endfor %}
      <div class="r grand"><span>{{ grand_total.label }}</span><span>{{ grand_total.value }}</span></div>
    </div>
  </div>

  <div class="footer">
    <div>{{ footer.terms | escape }}</div>
    {% if footer.platform %}<div style="margin-top:4px;">Service rendered via {{ footer.platform }}.</div>{% endif %}
    <div style="margin-top:4px;">{{ footer.disclaimer }}</div>
  </div>
</body>
</html>
